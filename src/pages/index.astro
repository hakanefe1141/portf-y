</style>

<script>
  // ── E-ÖĞRENİM MODÜLÜ ─────────────────────────────────────
  let currentSlide = 1;
  const TOTAL_SLIDES = 7;

  function showSlide(n) {
    document.querySelectorAll(".eslide").forEach(s => s.classList.remove("active"));
    document.querySelector(`.eslide[data-slide="${n}"]`)?.classList.add("active");
    document.getElementById("elearn-fill").style.width = (n / TOTAL_SLIDES * 100) + "%";
    document.getElementById("elearn-step-label").textContent = n + " / " + TOTAL_SLIDES;
    const prev = document.getElementById("elearn-prev");
    const next = document.getElementById("elearn-next");
    prev.disabled = n === 1;
    if (n === TOTAL_SLIDES) {
      next.textContent = "Tamamla ✓";
      next.classList.add("done");
    } else {
      next.textContent = "İleri →";
      next.classList.remove("done");
    }
    if (n === 3) animateStats();
  }

  window.eLearnNext = function() {
    if (currentSlide < TOTAL_SLIDES) { currentSlide++; showSlide(currentSlide); }
    else { markSectionDone("modul"); }
  };

  window.eLearnPrev = function() {
    if (currentSlide > 1) { currentSlide--; showSlide(currentSlide); }
  };

  function animateStats() {
    document.querySelectorAll(".estat-num").forEach(el => {
      const target = parseInt(el.getAttribute("data-target") || "0");
      let cur = 0;
      const step = Math.ceil(target / 40);
      const t = setInterval(() => {
        cur = Math.min(cur + step, target);
        el.textContent = String(cur);
        if (cur >= target) clearInterval(t);
      }, 35);
    });
  }

  window.mqAnswer = function(btn, correct) {
    document.querySelectorAll(".mq-opts button").forEach(b => {
      (b as HTMLButtonElement).disabled = true;
    });
    const fb = document.getElementById("mq-feedback");
    if (correct) {
      btn.classList.add("mq-correct");
      fb.innerHTML = '<span style="color:#22c55e">✓ Dogru! SCORM, e-ogrenme iceriklerinin LMS ile konusmasini saglayan bir standarttir.</span>';
    } else {
      btn.classList.add("mq-wrong");
      fb.innerHTML = '<span style="color:#ef4444">✗ Yanlis. Dogru cevap: E-ogrenme icerik ve LMS iletisim standardi.</span>';
      document.querySelectorAll(".mq-opts button")[1].classList.add("mq-correct");
    }
    fb.innerHTML += '<br/><button class="mq-reset-btn" onclick="resetModulQuiz()">↺ Tekrar Dene</button>';
    markSectionDone("modul-quiz");
  };

  window.resetModulQuiz = function() {
    document.getElementById("mq-feedback").innerHTML = "";
    document.querySelectorAll(".mq-opts button").forEach(b => {
      const el = b as HTMLButtonElement;
      el.disabled = false;
      el.classList.remove("mq-correct","mq-wrong");
    });
  };

  // ── TAMAMLAMA TAKİBİ & SERTİFİKA ────────────────────────
  const SECTIONS_TO_TRACK = ["hakkimda","deneyim","egitim","projeler","yetenekler","modul","iletisim"];
  const visitedSections = new Set();
  let certShown = false;

  const certObs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        visitedSections.add(e.target.id);
        if (!certShown && visitedSections.size >= SECTIONS_TO_TRACK.length) {
          certShown = true;
          setTimeout(() => document.getElementById("cert-overlay").classList.add("open"), 800);
        }
      }
    });
  }, { threshold: 0.3 });

  SECTIONS_TO_TRACK.forEach(id => {
    const el = document.getElementById(id);
    if (el) certObs.observe(el);
  });

  function markSectionDone(id) { visitedSections.add(id); }

  window.generateCert = function() {
    const name = (document.getElementById("cert-name") as HTMLInputElement).value.trim();
    if (!name) { alert("Lütfen adını yaz!"); return; }

    const canvas = document.getElementById("cert-canvas") as HTMLCanvasElement;
    canvas.width = 900;
    canvas.height = 620;
    canvas.style.display = "block";
    const ctx = canvas.getContext("2d")!;

    // Arka plan gradyanı
    const grad = ctx.createLinearGradient(0, 0, 900, 620);
    grad.addColorStop(0, "#0f0f1a");
    grad.addColorStop(1, "#1a0a2e");
    ctx.fillStyle = grad;
    ctx.roundRect(0, 0, 900, 620, 16);
    ctx.fill();

    // Kenar çerçevesi
    ctx.strokeStyle = "#7c3aed";
    ctx.lineWidth = 3;
    ctx.roundRect(16, 16, 868, 588, 12);
    ctx.stroke();

    ctx.strokeStyle = "rgba(167,139,250,0.3)";
    ctx.lineWidth = 1;
    ctx.roundRect(24, 24, 852, 572, 10);
    ctx.stroke();

    // Köşe süsler
    [[36,36],[864,36],[36,584],[864,584]].forEach(([x,y]) => {
      ctx.fillStyle = "#7c3aed";
      ctx.beginPath();
      ctx.arc(x, y, 5, 0, Math.PI * 2);
      ctx.fill();
    });

    // Başlık
    ctx.fillStyle = "#a78bfa";
    ctx.font = "bold 14px Georgia";
    ctx.textAlign = "center";
    ctx.fillText("HAKAN EFE  -  EGITIM TEKNOLOGU PORTFOLYOSU", 450, 68);

    ctx.fillStyle = "rgba(167,139,250,0.2)";
    ctx.fillRect(80, 80, 740, 1);

    // Rozet
    ctx.font = "52px Georgia";
    ctx.fillText("*", 450, 158);

    // Sertifika başlığı
    ctx.fillStyle = "#e2e8f0";
    ctx.font = "bold 26px Georgia";
    ctx.fillText("TAMAMLAMA SERTIFIKASI", 450, 222);

    // Alt metin
    ctx.fillStyle = "#94a3b8";
    ctx.font = "15px Georgia";
    ctx.fillText("Bu sertifika asagidaki kisinin", 450, 268);

    // İsim
    ctx.fillStyle = "#c084fc";
    ctx.font = "bold 38px Georgia";
    ctx.fillText(name.toUpperCase(), 450, 332);

    // Ayraç çizgi
    ctx.strokeStyle = "rgba(192,132,252,0.4)";
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(200, 350); ctx.lineTo(700, 350);
    ctx.stroke();

    // Açıklama
    ctx.fillStyle = "#94a3b8";
    ctx.font = "15px Georgia";
    ctx.fillText("Hakan Efe'nin egitim teknologu portfolyosunu eksiksiz", 450, 390);
    ctx.fillText("inceledigini ve tum moduller basariyla tamamladigini belgeler.", 450, 414);

    // Tarih & imza
    const today = new Date().toLocaleDateString("tr-TR", { day:"numeric", month:"long", year:"numeric" });
    ctx.fillStyle = "#64748b";
    ctx.font = "13px Georgia";
    ctx.textAlign = "left";
    ctx.fillText("Tarih: " + today, 100, 510);

    ctx.textAlign = "right";
    ctx.fillText("Hakan Efe", 800, 505);
    ctx.fillStyle = "#a78bfa";
    ctx.font = "12px Georgia";
    ctx.fillText("Egitim Teknologu", 800, 524);

    // Alt çizgi (imza görseli yerine)
    ctx.strokeStyle = "rgba(100,116,139,0.4)";
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(80, 520); ctx.lineTo(300, 520);
    ctx.moveTo(680, 520); ctx.lineTo(820, 520);
    ctx.stroke();

    // İndir linki
    const link = document.getElementById("cert-download") as HTMLAnchorElement;
    link.href = canvas.toDataURL("image/png");
    link.download = "HakanEfe_Sertifika.png";
    link.style.display = "inline-block";
  };

  // ── 1. TERMİNAL AÇILIŞ ───────────────────────────────────
  const TERMINAL_LINES = [
    "$ whoami",
    "> Hakan Efe — Eğitim Teknoloğu",
    "$ cat hakkimda.txt",
    "> Marmara Üni. BÖTE mezunu, Y.L. öğrencisi.",
    "> E-öğrenme & LMS uzmanı.",
    "$ ls deneyim/",
    "> EBİTEKAM  UZEM  TBV  Zübeyde_Hanım  YDYO",
    "$ ./portfolio --start",
    "> Portföy yükleniyor... ✓",
  ];

  const termText = document.getElementById("terminal-text");
  const overlay = document.getElementById("terminal-overlay");
  let lineI = 0, charI = 0, termDone = false;

  function typeTerminal() {
    if (termDone) return;
    if (lineI >= TERMINAL_LINES.length) {
      setTimeout(skipTerminal, 600);
      return;
    }
    const line = TERMINAL_LINES[lineI];
    if (charI < line.length) {
      termText.innerHTML += line[charI] === "<" ? "&lt;" : line[charI];
      charI++;
      setTimeout(typeTerminal, line.startsWith("$") ? 45 : 28);
    } else {
      termText.innerHTML += "\n";
      charI = 0;
      lineI++;
      setTimeout(typeTerminal, 320);
    }
  }

  function skipTerminal() {
    termDone = true;
    overlay.classList.add("hidden");
    setTimeout(() => overlay.remove(), 700);
  }

  window.skipTerminal = skipTerminal;
  setTimeout(typeTerminal, 400);

  // ── 2. ZİYARETÇİ SAYACI ──────────────────────────────────
  const BASE = 1247;
  let count = parseInt(localStorage.getItem("vc_count") || "0");
  if (!localStorage.getItem("vc_visited")) {
    count = BASE + Math.floor(Math.random() * 80);
    localStorage.setItem("vc_count", String(count));
    localStorage.setItem("vc_visited", "1");
  }
  const vcEl = document.getElementById("visitor-count");
  let vcCur = count - 30;
  const vcTimer = setInterval(() => {
    vcCur = Math.min(vcCur + 1, count);
    if (vcEl) vcEl.textContent = vcCur.toLocaleString("tr-TR");
    if (vcCur >= count) clearInterval(vcTimer);
  }, 40);

  // ── 3. SCROLL REVEAL ──────────────────────────────────────
  const revealObs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add("visible");
        revealObs.unobserve(e.target);
      }
    });
  }, { threshold: 0.12 });

  document.querySelectorAll(".reveal").forEach(el => revealObs.observe(el));

  // ── 4. KAÇAN BUTON + CONFETTİ ────────────────────────────
  let escapeCount = 0;

  window.runAway = function(btn) {
    escapeCount++;
    if (escapeCount >= 4) {
      btn.classList.add("caught");
      btn.textContent = "Yakaladın! 🎉";
      btn.onmouseenter = null;
      launchConfetti();
      return;
    }
    const wrap = btn.parentElement;
    const wRect = wrap.getBoundingClientRect();
    const maxX = window.innerWidth - wRect.width - 20;
    const maxY = window.innerHeight - 60;
    const rx = Math.max(20, Math.random() * maxX);
    const ry = Math.max(20, Math.random() * maxY);
    btn.style.position = "fixed";
    btn.style.left = rx + "px";
    btn.style.top = ry + "px";
    btn.style.zIndex = "7000";
    btn.style.transition = "left 0.18s, top 0.18s";
  };

  function launchConfetti() {
    const cc = document.getElementById("confetti-canvas");
    cc.style.display = "block";
    cc.width = window.innerWidth;
    cc.height = window.innerHeight;
    const ctx = cc.getContext("2d");
    const pieces = Array.from({ length: 160 }, () => ({
      x: Math.random() * cc.width,
      y: -20,
      r: Math.random() * 8 + 4,
      color: ["#7c3aed","#a78bfa","#c084fc","#22c55e","#fbbf24","#f472b6"][Math.floor(Math.random()*6)],
      vx: (Math.random()-0.5)*6,
      vy: Math.random()*4+2,
      rot: Math.random()*360,
      vr: (Math.random()-0.5)*8,
    }));
    let frame = 0;
    function drawConfetti() {
      ctx.clearRect(0, 0, cc.width, cc.height);
      pieces.forEach(p => {
        p.x += p.vx; p.y += p.vy; p.rot += p.vr; p.vy += 0.08;
        ctx.save();
        ctx.translate(p.x, p.y);
        ctx.rotate(p.rot * Math.PI/180);
        ctx.fillStyle = p.color;
        ctx.fillRect(-p.r/2, -p.r/2, p.r, p.r * 0.5);
        ctx.restore();
      });
      frame++;
      if (frame < 160) requestAnimationFrame(drawConfetti);
      else { cc.style.display = "none"; ctx.clearRect(0,0,cc.width,cc.height); }
    }
    drawConfetti();
  }

  // ── 5. MİNİ QUIZ ─────────────────────────────────────────
  const QUESTIONS = [
    {
      q: "Hakan hangi üniversitede okudu?",
      opts: ["İstanbul Teknik Üniversitesi","Marmara Üniversitesi","Boğaziçi Üniversitesi","Hacettepe Üniversitesi"],
      ans: 1,
    },
    {
      q: "Hakan'ın bölümünün kısaltması nedir?",
      opts: ["BÖTE","BİLMÜH","EDS","YTE"],
      ans: 0,
    },
    {
      q: "Hakan hangi kuruluşta araştırmacı olarak çalışıyor?",
      opts: ["TÜBİTAK","TBV","EBİTEKAM","UZEM"],
      ans: 2,
    },
    {
      q: "Hakan'ın e-posta adresi hangisi?",
      opts: ["hakan@marmara.edu.tr","hakanefe1141@gmail.com","hefe@hotmail.com","hakan.efe@tbv.org"],
      ans: 1,
    },
    {
      q: "Hakan hangi e-öğrenme aracını kullanıyor?",
      opts: ["Adobe Premiere","Articulate Storyline","Final Cut Pro","DaVinci Resolve"],
      ans: 1,
    },
  ];

  let qIdx = 0, score = 0, answered = false;

  function renderQuiz() {
    const c = document.getElementById("quiz-content");
    if (qIdx >= QUESTIONS.length) {
      const pct = Math.round((score / QUESTIONS.length) * 100);
      const msg = pct === 100 ? "Mükemmel! Hakan'ı çok iyi tanıyorsun 🏆"
                : pct >= 60 ? "Fena değil! Biraz daha öğrenebilirsin 😊"
                : "Portföyü biraz daha incele! 😄";
      c.innerHTML = `<div class="quiz-result">
        <div class="score">${score}/${QUESTIONS.length}</div>
        <p>${msg}</p>
        <button class="quiz-restart" onclick="restartQuiz()">Tekrar Dene 🔄</button>
      </div>`;
      if (pct === 100) launchConfetti();
      return;
    }
    const q = QUESTIONS[qIdx];
    c.innerHTML = `
      <p class="quiz-progress">Soru ${qIdx+1} / ${QUESTIONS.length}</p>
      <p class="quiz-q">${q.q}</p>
      <div class="quiz-options">
        ${q.opts.map((o,i) => `<button class="quiz-opt" onclick="answerQuiz(${i},this)">${o}</button>`).join("")}
      </div>`;
    answered = false;
  }

  window.answerQuiz = function(i, btn) {
    if (answered) return;
    answered = true;
    const q = QUESTIONS[qIdx];
    document.querySelectorAll(".quiz-opt").forEach((b, idx) => {
      (b as HTMLElement).style.pointerEvents = "none";
      if (idx === q.ans) b.classList.add("correct");
    });
    if (i === q.ans) { score++; }
    else { btn.classList.add("wrong"); }
    setTimeout(() => { qIdx++; renderQuiz(); }, 900);
  };

  window.openQuiz = function() {
    qIdx = 0; score = 0;
    document.getElementById("quiz-overlay").classList.add("open");
    renderQuiz();
  };

  window.closeQuiz = function(e?: any) {
    if (!e || e.target === document.getElementById("quiz-overlay"))
      document.getElementById("quiz-overlay").classList.remove("open");
  };

  window.restartQuiz = function() { qIdx = 0; score = 0; renderQuiz(); };

  const canvas = document.getElementById("particles-canvas") as HTMLCanvasElement;
  const ctx = canvas.getContext("2d")!;

  type Star = { x: number; y: number; vx: number; vy: number; r: number; alpha: number; twinkleSpeed: number; twinkleOffset: number; };
  let stars: Star[] = [];
  const STAR_COUNT = 220;
  const CONNECT_DIST = 110;

  function resize() {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
  }

  function initStars() {
    stars = Array.from({ length: STAR_COUNT }, () => {
      const angle = Math.random() * Math.PI * 2;
      const speed = Math.random() * 0.55 + 0.15;
      return {
        x: Math.random() * canvas.width,
        y: Math.random() * canvas.height,
        vx: Math.cos(angle) * speed,
        vy: Math.sin(angle) * speed,
        r: Math.random() * 1.8 + 0.3,
        alpha: Math.random() * 0.65 + 0.2,
        twinkleSpeed: Math.random() * 0.04 + 0.01,
        twinkleOffset: Math.random() * Math.PI * 2,
      };
    });
  }

  let frame = 0;
  function draw() {
    frame++;
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    const isDark = document.documentElement.getAttribute("data-theme") !== "light";
    const starColor = isDark ? "200, 180, 255" : "109, 40, 217";
    const lineColor = isDark ? "168, 139, 250" : "124, 58, 237";

    for (const s of stars) {
      s.x += s.vx;
      s.y += s.vy;
      if (s.x < 0) s.x = canvas.width;
      if (s.x > canvas.width) s.x = 0;
      if (s.y < 0) s.y = canvas.height;
      if (s.y > canvas.height) s.y = 0;

      const twinkle = s.alpha * (0.6 + 0.4 * Math.sin(frame * s.twinkleSpeed + s.twinkleOffset));

      // Parlak nokta
      ctx.beginPath();
      ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(${starColor}, ${twinkle})`;
      ctx.fill();

      // Büyük yıldızlara çapraz ışıma efekti
      if (s.r > 1.2) {
        const len = s.r * 3.5;
        ctx.save();
        ctx.globalAlpha = twinkle * 0.35;
        ctx.strokeStyle = `rgba(${starColor}, 1)`;
        ctx.lineWidth = 0.4;
        ctx.beginPath();
        ctx.moveTo(s.x - len, s.y); ctx.lineTo(s.x + len, s.y);
        ctx.moveTo(s.x, s.y - len); ctx.lineTo(s.x, s.y + len);
        ctx.stroke();
        ctx.restore();
      }
    }

    // Bağlantı çizgileri
    for (let i = 0; i < stars.length; i++) {
      for (let j = i + 1; j < stars.length; j++) {
        const dx = stars[i].x - stars[j].x;
        const dy = stars[i].y - stars[j].y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < CONNECT_DIST) {
          ctx.beginPath();
          ctx.moveTo(stars[i].x, stars[i].y);
          ctx.lineTo(stars[j].x, stars[j].y);
          ctx.strokeStyle = `rgba(${lineColor}, ${0.07 * (1 - dist / CONNECT_DIST)})`;
          ctx.lineWidth = 0.4;
          ctx.stroke();
        }
      }
    }

    requestAnimationFrame(draw);
  }

  resize();
  initStars();
  draw();
  window.addEventListener("resize", () => { resize(); initStars(); });

  // ── BLOG CAROUSEL ────────────────────────────────────────
  let blogPosts = [];
  let blogIndex = 0;
  const BLOG_VISIBLE = 3;

  async function loadBlog() {
    try {
      const res = await fetch(
        "https://firestore.googleapis.com/v1/projects/hakan-efe-portfolyo/databases/(default)/documents/blog?orderBy=date%20desc&pageSize=20"
      );
      const data = await res.json();
      blogPosts = (data.documents || []).map(doc => ({
        id: doc.name.split("/").pop(),
        title:  doc.fields.title?.stringValue  || "",
        tag:    doc.fields.tag?.stringValue    || "Genel",
        body:   doc.fields.body?.stringValue   || "",
        author: doc.fields.author?.stringValue || "Hakan Efe",
        date:   doc.fields.date?.stringValue   || "",
      }));

      const track = document.getElementById("blog-track");

      if (!blogPosts.length) {
        track.innerHTML = `<div class="blog-empty">📝 Henüz yazı yok — yakında yeni içerikler gelecek!</div>`;
        return;
      }

      track.innerHTML = blogPosts.map((p, i) => {
        const date = new Date(p.date).toLocaleDateString("tr-TR", { day:"numeric", month:"long", year:"numeric" });
        const excerpt = p.body.slice(0, 120) + (p.body.length > 120 ? "..." : "");
        return `<div class="blog-card" onclick="openBlogPost(${i})">
          <span class="blog-card-tag">${p.tag}</span>
          <div class="blog-card-title">${p.title}</div>
          <div class="blog-card-excerpt">${excerpt}</div>
          <div class="blog-card-meta">
            <span>${p.author}</span>
            <span>${date}</span>
          </div>
        </div>`;
      }).join("");

      updateBlogNav();
    } catch {
      document.getElementById("blog-track").innerHTML =
        `<div class="blog-empty">Yazılar yüklenemedi.</div>`;
    }
  }

  function updateBlogNav() {
    const cardW = 320;
    document.getElementById("blog-track").style.transform =
      `translateX(-${blogIndex * cardW}px)`;
    const prev = document.getElementById("blog-prev");
    const next = document.getElementById("blog-next");
    if (prev) prev.disabled = blogIndex === 0;
    if (next) next.disabled = blogIndex >= blogPosts.length - BLOG_VISIBLE;
  }

  window.blogScroll = function(dir) {
    const max = Math.max(0, blogPosts.length - BLOG_VISIBLE);
    blogIndex = Math.max(0, Math.min(blogIndex + dir, max));
    updateBlogNav();
  };

  window.openBlogPost = function(i) {
    const p = blogPosts[i];
    const date = new Date(p.date).toLocaleDateString("tr-TR", { day:"numeric", month:"long", year:"numeric" });
    document.getElementById("bm-tag").textContent = p.tag;
    document.getElementById("bm-title").textContent = p.title;
    document.getElementById("bm-meta").textContent = `${p.author} · ${date}`;
    document.getElementById("bm-body").textContent = p.body;
    document.getElementById("blog-modal").classList.add("open");
    document.body.style.overflow = "hidden";
  };

  window.closeBlogPost = function(e?: any) {
    if (!e || e.target === document.getElementById("blog-modal")) {
      document.getElementById("blog-modal").classList.remove("open");
      document.body.style.overflow = "";
    }
  };

  loadBlog();

  // ── GERİ BİLDİRİM FORMU ──────────────────────────────────
  let selectedStar = 0;

  window.setStar = function(n) {
    selectedStar = n;
    document.querySelectorAll(".stars-row button").forEach((b, i) => {
      b.classList.toggle("active", i < n);
    });
  };

  window.submitFeedback = async function(e) {
    e.preventDefault();
    const btn = document.getElementById("fb-submit-btn");
    btn.disabled = true;
    btn.textContent = "Gönderiliyor...";

    const data = {
      name: (document.getElementById("fb-name") as HTMLInputElement).value,
      email: (document.getElementById("fb-email") as HTMLInputElement).value,
      stars: selectedStar || 5,
      message: (document.getElementById("fb-message") as HTMLTextAreaElement).value,
      date: new Date().toISOString(),
    };

    try {
      await fetch(
        "https://firestore.googleapis.com/v1/projects/hakan-efe-portfolyo/databases/(default)/documents/feedback",
        {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            fields: {
              name:    { stringValue: data.name },
              email:   { stringValue: data.email },
              stars:   { integerValue: data.stars },
              message: { stringValue: data.message },
              date:    { stringValue: data.date },
            }
          })
        }
      );
      document.getElementById("fb-success").style.display = "block";
      (document.getElementById("feedback-form") as HTMLFormElement).reset();
      selectedStar = 0;
      document.querySelectorAll(".stars-row button").forEach(b => b.classList.remove("active"));
    } catch {
