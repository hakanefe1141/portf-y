    gap: 8px;
    background: var(--accent-glow);
    border: 1px solid var(--accent);
    color: var(--accent-light);
    border-radius: 100px;
    padding: 4px 16px;
    font-size: 0.82rem;
    font-weight: 500;
    margin-bottom: 28px;
  }

  .hero-badge::before {
    content: "";
    width: 8px;
    height: 8px;
    background: #22c55e;
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  h1 {
    font-size: clamp(2.4rem, 6vw, 3.8rem);
    font-weight: 700;
    line-height: 1.15;
    margin-bottom: 16px;
  }

  .hero-name {
    background: linear-gradient(135deg, var(--accent-light) 0%, #c084fc 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-title {
    font-size: 1.2rem;
    color: var(--text-dim);
    font-weight: 500;
    margin-bottom: 20px;
    font-family: "JetBrains Mono", monospace;
  }

  .hero-title::before {
    content: "→ ";
    color: var(--accent-light);
  }

  .hero-desc {
    color: var(--text-muted);
    font-size: 1.02rem;
    max-width: 580px;
    margin-bottom: 36px;
    line-height: 1.8;
  }

  .hero-cta {
    display: flex;
    gap: 16px;
    margin-bottom: 36px;
    flex-wrap: wrap;
  }

  .btn-primary {
    background: var(--accent);
    color: white !important;
    padding: 12px 28px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.92rem;
    transition: opacity 0.2s, transform 0.2s;
  }

  .btn-primary:hover {
    opacity: 0.9 !important;
    transform: translateY(-2px);
  }

  .btn-secondary {
    background: transparent;
    color: var(--text) !important;
    padding: 12px 28px;
    border-radius: 8px;
    border: 1px solid var(--border);
    font-weight: 600;
    font-size: 0.92rem;
    transition: border-color 0.2s, transform 0.2s;
  }

  .btn-secondary:hover {
    border-color: var(--accent);
    opacity: 1 !important;
    transform: translateY(-2px);
  }

  .btn-cv {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    background: transparent;
    color: var(--text-muted) !important;
    padding: 12px 20px;
    border-radius: 8px;
    border: 1px dashed var(--border);
    font-weight: 600;
    font-size: 0.88rem;
    transition: border-color 0.2s, color 0.2s, transform 0.2s;
  }

  .btn-cv:hover {
    border-color: var(--accent-light);
    color: var(--accent-light) !important;
    opacity: 1 !important;
    transform: translateY(-2px);
  }

  .hero-socials { display: flex; gap: 12px; }

  .hero-socials a {
    color: var(--text-muted);
    display: flex;
    align-items: center;
    padding: 8px;
    border-radius: 8px;
    border: 1px solid var(--border);
    transition: color 0.2s, border-color 0.2s;
  }

  .hero-socials a:hover {
    color: var(--accent-light);
    border-color: var(--accent);
    opacity: 1;
  }

  /* ABOUT */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 270px;
    gap: 48px;
    align-items: start;
  }

  .about-text p {
    color: var(--text-dim);
    margin-bottom: 16px;
    line-height: 1.8;
  }

  .about-info {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .info-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .info-label {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted);
  }

  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: #22c55e;
    font-weight: 500;
  }

  .status-badge::before {
    content: "";
    width: 8px;
    height: 8px;
    background: #22c55e;
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  /* TIMELINE */
  .timeline { display: flex; flex-direction: column; gap: 20px; }

  .timeline-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 14px;
    gap: 16px;
  }

  .timeline-header h3 {
    font-size: 1.05rem;
    font-weight: 600;
    margin-bottom: 4px;
  }

  .org {
    color: var(--accent-light);
    font-size: 0.88rem;
    font-weight: 500;
  }

  .date-badge {
    background: var(--tag-bg);
    color: var(--text-muted);
    border-radius: 6px;
    padding: 4px 12px;
    font-size: 0.76rem;
    font-family: "JetBrains Mono", monospace;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .timeline-list { list-style: none; margin-bottom: 14px; }

  .timeline-list li {
    color: var(--text-dim);
    padding: 3px 0 3px 16px;
    position: relative;
    font-size: 0.92rem;
  }

  .timeline-list li::before {
    content: "▸";
    position: absolute;
    left: 0;
    color: var(--accent-light);
  }

  .tag-row { display: flex; flex-wrap: wrap; gap: 8px; }

  /* EDUCATION */
  .edu-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 20px;
  }

  .edu-card {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .edu-icon { font-size: 2rem; flex-shrink: 0; }

  .edu-card h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 4px;
  }

  .edu-field {
    color: var(--text-muted);
    font-size: 0.85rem;
    margin: 4px 0 10px;
  }

  /* SKILLS */
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
    gap: 20px;
  }

  .skill-cat {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--accent-light);
    text-transform: uppercase;
    letter-spacing: 0.07em;
    margin-bottom: 20px;
    font-family: "JetBrains Mono", monospace;
  }

  .skill-list { display: flex; flex-direction: column; gap: 14px; }

  .skill-item { display: flex; flex-direction: column; gap: 6px; }

  .skill-item span {
    font-size: 0.88rem;
    color: var(--text-dim);
  }

  .skill-bar {
    height: 4px;
    background: var(--border);
    border-radius: 2px;
    overflow: hidden;
  }

  .skill-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--accent), var(--accent-light));
    border-radius: 2px;
  }

  .tag-cloud { display: flex; flex-wrap: wrap; gap: 8px; }

  /* REFERANSLAR */
  .ref-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
  }

  .ref-card {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .ref-avatar {
    width: 52px;
    height: 52px;
    background: var(--accent-glow);
    border: 2px solid var(--accent);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    color: var(--accent-light);
    font-family: "JetBrains Mono", monospace;
    font-size: 0.9rem;
    flex-shrink: 0;
  }

  .ref-card h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 4px;
  }

  .ref-contact {
    font-size: 0.85rem;
    color: var(--text-muted);
    display: block;
    margin-top: 4px;
  }

  /* CONTACT */
  .contact-wrapper { max-width: 640px; }

  .contact-text {
    color: var(--text-dim);
    font-size: 1.05rem;
    line-height: 1.7;
    margin-bottom: 32px;
  }

  .contact-cards { display: flex; flex-direction: column; gap: 14px; }

  .contact-card {
    display: flex;
    align-items: center;
    gap: 20px;
    color: var(--text) !important;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }

  .contact-card:hover {
    transform: translateX(6px);
    opacity: 1 !important;
  }

  .contact-card svg {
    color: var(--accent-light);
    flex-shrink: 0;
  }

  .contact-label {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted);
    margin-bottom: 2px;
  }

  /* TERMİNAL */
  #terminal-overlay {
    position: fixed;
    inset: 0;
    background: #0a0a0f;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.6s ease;
  }

  #terminal-overlay.hidden {
    opacity: 0;
    pointer-events: none;
  }

  #terminal-box {
    width: min(640px, 90vw);
    background: #111118;
    border: 1px solid #2a2a3e;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 0 60px rgba(124,58,237,0.2);
  }

  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 12px 16px;
    background: #1a1a2e;
    border-bottom: 1px solid #2a2a3e;
  }

  .t-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .t-title {
    margin-left: 8px;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.8rem;
    color: #64748b;
  }

  #terminal-body {
    padding: 24px;
    min-height: 220px;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.9rem;
    line-height: 2;
    color: #a78bfa;
  }

  .t-cursor {
    animation: blink 0.7s infinite;
    color: #a78bfa;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  #terminal-skip {
    display: block;
    margin: 0 16px 16px auto;
    background: none;
    border: 1px solid #2a2a3e;
    color: #64748b;
    border-radius: 6px;
    padding: 6px 14px;
    font-size: 0.8rem;
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s;
  }

  #terminal-skip:hover { border-color: #a78bfa; color: #a78bfa; }

  /* CONFETTİ */
  #confetti-canvas {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 9000;
    display: none;
  }

  /* ZİYARETÇİ SAYACI */
  .hero-top-row {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 28px;
    flex-wrap: wrap;
  }

  .visitor-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    color: var(--text-muted);
    border-radius: 100px;
    padding: 4px 14px;
    font-size: 0.78rem;
    font-family: "JetBrains Mono", monospace;
  }

  /* SCROLL REVEAL */
  .reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }

  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* KAÇAN BUTON */
  .contact-actions {
    display: flex;
    gap: 16px;
    margin-top: 24px;
    flex-wrap: wrap;
    align-items: center;
  }

  .runaway-wrap {
    position: relative;
    width: 160px;
    height: 48px;
  }

  #hire-btn {
    position: absolute;
    background: linear-gradient(135deg, var(--accent), #c084fc);
    color: white;
    border: none;
    border-radius: 8px;
    padding: 12px 20px;
    font-weight: 700;
    font-size: 0.9rem;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.2s;
    font-family: "Inter", sans-serif;
  }

  #hire-btn.caught {
    position: static;
    animation: caught-bounce 0.4s ease;
  }

  @keyframes caught-bounce {
    0% { transform: scale(1); }
    40% { transform: scale(1.15); }
    100% { transform: scale(1); }
  }

  .quiz-trigger-btn {
    background: var(--bg-card);
    border: 1px solid var(--accent);
    color: var(--accent-light);
    border-radius: 8px;
    padding: 12px 20px;
    font-weight: 600;
    font-size: 0.9rem;
    cursor: pointer;
    font-family: "Inter", sans-serif;
    transition: background 0.2s, transform 0.2s;
  }

  .quiz-trigger-btn:hover {
    background: var(--accent-glow);
    transform: translateY(-2px);
  }

  /* QUIZ MODAL */
  #quiz-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.7);
    z-index: 8000;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(4px);
  }

  #quiz-overlay.open { display: flex; }

  #quiz-box {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 36px;
    width: min(480px, 90vw);
    position: relative;
    box-shadow: 0 20px 60px rgba(0,0,0,0.4);
    animation: quiz-in 0.3s ease;
  }

  @keyframes quiz-in {
    from { opacity:0; transform: scale(0.95) translateY(20px); }
    to { opacity:1; transform: scale(1) translateY(0); }
  }

  .quiz-close-btn {
    position: absolute;
    top: 16px; right: 16px;
    background: none; border: none;
    color: var(--text-muted); font-size: 1.1rem;
    cursor: pointer;
  }

  .quiz-progress {
    font-size: 0.78rem;
    color: var(--text-muted);
    font-family: "JetBrains Mono", monospace;
    margin-bottom: 8px;
  }

  .quiz-q {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 24px;
    line-height: 1.5;
  }

  .quiz-options {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .quiz-opt {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 12px 16px;
    text-align: left;
    cursor: pointer;
    font-size: 0.92rem;
    color: var(--text);
    font-family: "Inter", sans-serif;
    transition: border-color 0.15s, background 0.15s;
  }

  .quiz-opt:hover { border-color: var(--accent); background: var(--accent-glow); }
  .quiz-opt.correct { border-color: #22c55e; background: rgba(34,197,94,0.1); color: #22c55e; }
  .quiz-opt.wrong { border-color: #ef4444; background: rgba(239,68,68,0.1); color: #ef4444; }

  .quiz-result {
    text-align: center;
    padding: 12px 0;
  }

  .quiz-result .score {
    font-size: 3rem;
    font-weight: 700;
    background: linear-gradient(135deg, var(--accent-light), #c084fc);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .quiz-result p { color: var(--text-dim); margin: 8px 0 20px; }

  .quiz-restart {
    background: var(--accent);
    color: white;
    border: none;
    border-radius: 8px;
    padding: 10px 24px;
    font-weight: 600;
    cursor: pointer;
    font-family: "Inter", sans-serif;
  }

  /* PROJELER */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
  }

  .project-featured {
    border-color: var(--accent) !important;
    background: linear-gradient(135deg, var(--bg-card), rgba(124,58,237,0.04)) !important;
    position: relative;
  }

  .project-new-badge {
    display: inline-block;
    background: var(--accent);
    color: white;
    font-size: 0.7rem;
    font-weight: 700;
    padding: 2px 10px;
    border-radius: 100px;
    margin-bottom: 8px;
    letter-spacing: 0.05em;
  }

  .project-card h3 {
    font-size: 1.05rem;
    font-weight: 600;
    margin-bottom: 10px;
  }

  .project-card p {
    color: var(--text-dim);
    font-size: 0.9rem;
    line-height: 1.7;
    margin-bottom: 16px;
  }

  .project-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 14px;
  }

  .project-icon { font-size: 2rem; }

  .project-links a {
    color: var(--text-muted);
    display: flex;
    align-items: center;
    padding: 6px;
    border-radius: 6px;
    border: 1px solid var(--border);
    transition: color 0.2s, border-color 0.2s;
  }

  .project-links a:hover {
    color: var(--accent-light);
    border-color: var(--accent);
    opacity: 1;
  }

  /* E-ÖĞRENİM MODÜLÜ */
  .modul-subtitle {
    color: var(--text-muted);
    margin-top: -32px;
    margin-bottom: 32px;
    font-size: 0.95rem;
  }

  #elearn-box {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
    max-width: 760px;
  }

  .elearn-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 24px;
    background: linear-gradient(135deg, var(--accent), #7e22ce);
    gap: 16px;
    flex-wrap: wrap;
  }

  .elearn-course-name {
    color: white;
    font-weight: 600;
    font-size: 0.9rem;
  }

  .elearn-progress-wrap {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .elearn-progress-bar {
    width: 140px;
    height: 6px;
    background: rgba(255,255,255,0.25);
    border-radius: 3px;
    overflow: hidden;
  }

  #elearn-fill {
    height: 100%;
    background: white;
    border-radius: 3px;
    width: 25%;
    transition: width 0.4s ease;
  }

  #elearn-step-label {
    color: rgba(255,255,255,0.85);
    font-size: 0.78rem;
    font-family: "JetBrains Mono", monospace;
    white-space: nowrap;
  }

  #elearn-slides {
    padding: 36px 32px 24px;
    min-height: 300px;
  }

  .eslide { display: none; animation: slide-in 0.35s ease; }
  .eslide.active { display: block; }

  @keyframes slide-in {
    from { opacity:0; transform: translateX(20px); }
    to   { opacity:1; transform: translateX(0); }
  }

  .eslide-icon { font-size: 2.4rem; margin-bottom: 12px; }

  .eslide h3 {
    font-size: 1.3rem;
    font-weight: 700;
    margin-bottom: 16px;
  }

  .eslide p {
    color: var(--text-dim);
    line-height: 1.8;
    margin-bottom: 12px;
  }

  .eslide-tag-row { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 16px; }

  .eslide-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-bottom: 12px;
  }

  .eslide-card {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 18px;
    cursor: pointer;
    min-height: 90px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    font-size: 0.85rem;
    font-weight: 600;
    transition: border-color 0.2s, transform 0.2s;
    position: relative;
    perspective: 600px;
  }

  .eslide-card:hover { border-color: var(--accent); transform: translateY(-2px); }

  .ec-front, .ec-back {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    padding: 12px;
    border-radius: 10px;
    backface-visibility: hidden;
    transition: transform 0.4s;
    font-size: 0.82rem;
    line-height: 1.5;
  }

  .ec-front { background: var(--bg); font-weight: 600; }
  .ec-back  { background: var(--accent-glow); color: var(--accent-light); transform: rotateY(180deg); font-weight: 400; }

  .eslide-card.flipped .ec-front { transform: rotateY(-180deg); }
  .eslide-card.flipped .ec-back  { transform: rotateY(0deg); }

  .eslide-hint {
    color: var(--text-muted);
    font-size: 0.8rem;
    margin-top: 4px !important;
  }

  .eslide-stats {
    display: flex;
    gap: 24px;
    justify-content: center;
    margin: 24px 0;
    flex-wrap: wrap;
  }

  .estat {
    text-align: center;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 20px 28px;
  }

  .estat-num {
    font-size: 2.8rem;
    font-weight: 700;
    background: linear-gradient(135deg, var(--accent-light), #c084fc);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-family: "JetBrains Mono", monospace;
  }

  .estat span:not(.estat-num) {
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--accent-light);
  }

  .estat p {
    font-size: 0.78rem;
    color: var(--text-muted);
    margin: 6px 0 0;
  }

  .mq-question {
    font-size: 1.05rem;
    font-weight: 600;
    margin-bottom: 20px;
  }

  .mq-opts {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .mq-opts button {
    background: var(--bg);
