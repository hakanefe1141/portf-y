---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Hakan Efe | Eğitim Teknoloğu">

  <!-- TERMİNAL AÇILIŞ -->
  <div id="terminal-overlay">
    <div id="terminal-box">
      <div class="terminal-bar">
        <span class="t-dot" style="background:#ff5f57"></span>
        <span class="t-dot" style="background:#ffbd2e"></span>
        <span class="t-dot" style="background:#28ca41"></span>
        <span class="t-title">hakan@portfolio ~ </span>
      </div>
      <div id="terminal-body">
        <div id="terminal-text"></div>
        <span class="t-cursor">█</span>
      </div>
      <button id="terminal-skip" onclick="skipTerminal()">Atla →</button>
    </div>
  </div>

  <!-- MİNİ QUIZ MODAL -->
  <div id="quiz-overlay" onclick="closeQuiz(event)">
    <div id="quiz-box">
      <button class="quiz-close-btn" onclick="closeQuiz()">✕</button>
      <div id="quiz-content"></div>
    </div>
  </div>

  <!-- CONFETTİ CANVAS -->
  <canvas id="confetti-canvas"></canvas>

  <!-- ANİMASYONLU ARKA PLAN -->
  <div class="bg-orbs" aria-hidden="true">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>
  </div>
  <canvas id="particles-canvas"></canvas>

  <!-- NAV -->
  <nav>
    <div class="container nav-inner">
      <span class="nav-logo">HE<span class="accent">.</span></span>
      <div class="nav-links">
        <a href="#hakkimda" id="nav-hakkimda-link">Hakkımda</a>
        <a href="#deneyim" id="nav-deneyim-link">Deneyim</a>
        <a href="#egitim" id="nav-egitim-link">Eğitim</a>
        <a href="#projeler" id="nav-projeler-link">Projeler</a>
        <a href="#modul" id="nav-modul-link">Modül</a>
        <a href="#yetenekler" id="nav-yetenekler-link">Yetenekler</a>
        <a href="#blog" id="nav-blog-link">Blog</a>
        <a href="#iletisim" id="nav-iletisim-link">İletişim</a>
        <button id="lang-toggle" onclick="toggleLang()" title="Switch language">🇹🇷</button>
        <button id="theme-toggle" onclick="toggleTheme()" aria-label="Tema değiştir">☀️</button>
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <section id="hero">
    <div class="container hero-layout">
      <div class="hero-inner">
        <div class="hero-top-row">
          <div class="hero-badge"><span id="hero-badge-text">Açık Pozisyonlara Müsait</span></div>
