            <a href="mailto:hakanefe1141@gmail.com">hakanefe1141@gmail.com</a>
          </div>
          <div class="info-item">
            <span class="info-label">Telefon</span>
            <a href="tel:+905522861141">+0 552 286 11 41</a>
          </div>
          <div class="info-item">
            <span class="info-label">Yabancı Dil</span>
            <span>İngilizce B1</span>
          </div>
          <div class="info-item">
            <span class="info-label">Durum</span>
            <span class="status-badge" id="status-text">Müsait</span>
          </div>
        </div>
