---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Admin Panel | Hakan Efe">
<div class="admin-page">

  <!-- GİRİŞ: ŞİFRE -->
  <div id="screen-pass">
    <div class="login-box">
      <div class="login-icon">🔐</div>
      <h1>Admin Girişi</h1>
      <p>Şifreni gir, ardından SMS doğrulaması yapılacak.</p>
      <input type="password" id="input-pass" placeholder="Şifre" onkeydown="if(event.key==='Enter') checkPass()" />
      <button onclick="checkPass()">Devam Et →</button>
      <p id="pass-error" class="error-msg" style="display:none">Yanlış şifre!</p>
    </div>
  </div>

  <!-- GİRİŞ: SMS DOĞRULAMA -->
  <div id="screen-sms" style="display:none">
    <div class="login-box">
      <div class="login-icon">📱</div>
      <h1>SMS Doğrulama</h1>
      <p>Telefonuna 6 haneli doğrulama kodu gönderildi.</p>
      <input type="text" id="input-code" placeholder="6 haneli kod" maxlength="6"
        onkeydown="if(event.key==='Enter') verifySMS()" style="text-align:center;letter-spacing:0.3em;font-size:1.4rem" />
      <button onclick="verifySMS()">Doğrula ✓</button>
      <button onclick="resendSMS()" class="resend-btn">Tekrar gönder</button>
      <p id="sms-error" class="error-msg" style="display:none">Hatalı kod!</p>
      <div id="recaptcha-container"></div>
    </div>
  </div>

  <!-- ADMIN PANELİ -->
  <div id="screen-admin" style="display:none">
    <header class="admin-header">
      <div class="admin-logo">⚙️ Admin Panel</div>
      <div class="admin-tabs">
        <button onclick="showTab('tab-write')" class="admin-tab active" id="btn-write">✏️ Yazı Yaz</button>
        <button onclick="showTab('tab-posts')" class="admin-tab" id="btn-posts">📋 Yazılarım</button>
        <button onclick="showTab('tab-feedback')" class="admin-tab" id="btn-feedback">💬 Yorumlar</button>
      </div>
      <button onclick="adminLogout()" class="logout-btn">Çıkış</button>
    </header>

    <main class="admin-main container">

      <!-- YENİ YAZI -->
      <div id="tab-write" class="admin-tab-content">
        <div class="admin-card">
          <h2>Yeni Blog Yazısı</h2>
          <form id="post-form" onsubmit="publishPost(event)">
            <input type="text" id="post-title" placeholder="Başlık *" required />
            <input type="text" id="post-tag" placeholder="Etiket (örn: E-Öğrenme, ADDIE, LMS)" />
            <textarea id="post-body" rows="16" placeholder="Yazı içeriği *" required></textarea>
            <div class="form-footer">
              <span id="char-count" class="char-count">0 karakter</span>
              <button type="submit" id="publish-btn">Yayınla 🚀</button>
            </div>
          </form>
          <div id="publish-success" class="success-toast" style="display:none">✅ Yazı yayınlandı!</div>
          <div id="publish-error" class="error-toast" style="display:none">❌ Hata oluştu.</div>
        </div>
      </div>

      <!-- YAZILARI -->
      <div id="tab-posts" class="admin-tab-content" style="display:none">
        <div class="admin-card">
          <div class="card-header">
            <h2>Yazılarım</h2>
            <button onclick="loadPosts()" class="refresh-btn">↺ Yenile</button>
          </div>
          <div id="posts-list"><p class="loading-p">Yükleniyor...</p></div>
        </div>
      </div>

      <!-- YORUMLAR -->
      <div id="tab-feedback" class="admin-tab-content" style="display:none">
        <div class="admin-card">
          <div class="card-header">
            <h2>Ziyaretçi Yorumları</h2>
            <button onclick="loadFeedback()" class="refresh-btn">↺ Yenile</button>
          </div>
          <div id="feedback-list"><p class="loading-p">Yükleniyor...</p></div>
        </div>
      </div>

    </main>
  </div>
</div>
</Layout>

<style>
  .admin-page { min-height:100vh; background:var(--bg); color:var(--text); font-family:"Inter",sans-serif; }
  .container { max-width:860px; margin:0 auto; padding:0 24px; }

  /* GİRİŞ EKRANI */
  #screen-pass, #screen-sms {
    min-height:100vh;
    display:flex; align-items:center; justify-content:center;
  }

  .login-box {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 48px 40px;
    width: min(420px, 92vw);
    text-align: center;
    display: flex; flex-direction: column; gap: 14px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.3);
  }

  .login-icon { font-size: 3rem; }
  .login-box h1 { font-size:1.6rem; font-weight:700; }
  .login-box > p { color:var(--text-muted); font-size:0.9rem; line-height:1.5; }

  .login-box input {
    width:100%; background:var(--bg);
    border:1px solid var(--border); border-radius:10px;
    padding:14px 16px; color:var(--text);
    font-size:1rem; font-family:"Inter",sans-serif;
    outline:none; transition:border-color 0.2s;
  }
  .login-box input:focus { border-color:var(--accent); }

  .login-box button {
    background: linear-gradient(135deg, var(--accent), #c084fc);
    color:white; border:none; border-radius:10px;
    padding:13px; font-weight:700; font-size:0.95rem;
    cursor:pointer; font-family:"Inter",sans-serif;
    transition:opacity 0.2s;
  }
  .login-box button:hover { opacity:0.88; }

  .resend-btn {
    background: none !important;
    border: 1px solid var(--border) !important;
    color: var(--text-muted) !important;
    font-size: 0.85rem !important;
    font-weight: 500 !important;
    padding: 10px !important;
  }

  .error-msg { color:#ef4444; font-size:0.85rem; }

  #recaptcha-container { display:flex; justify-content:center; }

  /* HEADER */
  .admin-header {
    display:flex; align-items:center; gap:16px;
    padding:14px 28px; background:var(--bg-card);
    border-bottom:1px solid var(--border);
    position:sticky; top:0; z-index:100;
    flex-wrap:wrap;
  }

  .admin-logo { font-weight:700; font-size:1rem; flex-shrink:0; }

  .admin-tabs { display:flex; gap:4px; flex:1; }

  .admin-tab {
    background:none; border:none; border-radius:8px;
    padding:8px 16px; font-size:0.85rem; font-weight:500;
    cursor:pointer; color:var(--text-muted);
    font-family:"Inter",sans-serif;
    transition:background 0.2s, color 0.2s;
  }
  .admin-tab:hover { background:var(--bg); color:var(--text); }
  .admin-tab.active {
    background:var(--accent-glow); color:var(--accent-light);
    border:1px solid rgba(124,58,237,0.3);
  }

  .logout-btn {
    background:rgba(239,68,68,0.08);
    border:1px solid rgba(239,68,68,0.25);
    color:#ef4444; border-radius:8px;
    padding:7px 16px; font-size:0.82rem;
    cursor:pointer; font-family:"Inter",sans-serif;
    margin-left:auto; flex-shrink:0;
  }

  /* PANEL */
  .admin-main { padding:32px 24px 60px; }
  .admin-card {
    background:var(--bg-card); border:1px solid var(--border);
    border-radius:14px; padding:28px;
  }
  .admin-card h2 { font-size:1.1rem; font-weight:700; margin-bottom:20px; }

  .card-header {
    display:flex; align-items:center; justify-content:space-between;
    margin-bottom:20px;
  }
  .card-header h2 { margin-bottom:0; }

  .refresh-btn {
    background:none; border:1px solid var(--border);
    color:var(--text-muted); border-radius:6px;
    padding:5px 14px; font-size:0.8rem;
    cursor:pointer; font-family:"Inter",sans-serif;
    transition:border-color 0.2s;
  }
  .refresh-btn:hover { border-color:var(--accent); }

  /* FORM */
  #post-form { display:flex; flex-direction:column; gap:12px; }
  #post-form input, #post-form textarea {
    background:var(--bg); border:1px solid var(--border);
    border-radius:10px; padding:12px 16px;
    color:var(--text); font-size:0.9rem;
    font-family:"Inter",sans-serif; outline:none;
    resize:vertical; transition:border-color 0.2s;
  }
  #post-form input:focus, #post-form textarea:focus { border-color:var(--accent); }

  .form-footer { display:flex; align-items:center; justify-content:space-between; }
  .char-count { font-size:0.75rem; color:var(--text-muted); font-family:"JetBrains Mono",monospace; }

  #publish-btn {
    background:linear-gradient(135deg,var(--accent),#c084fc);
    color:white; border:none; border-radius:8px;
    padding:10px 24px; font-weight:700; font-size:0.9rem;
    cursor:pointer; font-family:"Inter",sans-serif;
    transition:opacity 0.2s;
  }
  #publish-btn:hover { opacity:0.88; }
  #publish-btn:disabled { opacity:0.5; cursor:not-allowed; }

  .success-toast { color:#22c55e; font-weight:600; font-size:0.9rem; margin-top:8px; }
  .error-toast { color:#ef4444; font-weight:600; font-size:0.9rem; margin-top:8px; }

  /* YAZI / YORUM LİSTELERİ */
  .loading-p { color:var(--text-muted); font-size:0.9rem; }

  .post-item {
    display:flex; justify-content:space-between;
    align-items:flex-start; padding:16px 0;
    border-bottom:1px solid var(--border); gap:12px;
  }
  .post-item:last-child { border-bottom:none; }
  .post-item-title { font-weight:600; font-size:0.9rem; margin-bottom:4px; }
  .post-item-meta { font-size:0.75rem; color:var(--text-muted); font-family:"JetBrains Mono",monospace; }

  .delete-btn {
    background:rgba(239,68,68,0.08);
    border:1px solid rgba(239,68,68,0.2);
    color:#ef4444; border-radius:6px;
    padding:5px 12px; font-size:0.78rem;
    cursor:pointer; font-family:"Inter",sans-serif;
    white-space:nowrap; flex-shrink:0;
    transition:background 0.2s;
  }
  .delete-btn:hover { background:rgba(239,68,68,0.15); }

  /* YORUM KARTLARI */
  .feedback-item {
    background:var(--bg); border:1px solid var(--border);
    border-radius:12px; padding:18px; margin-bottom:12px;
  }
  .feedback-item:last-child { margin-bottom:0; }

  .fb-item-header {
    display:flex; align-items:center; justify-content:space-between;
    margin-bottom:10px; flex-wrap:wrap; gap:8px;
  }

  .fb-item-name { font-weight:600; font-size:0.95rem; }
  .fb-item-email { font-size:0.78rem; color:var(--text-muted); }

  .fb-stars-display { color:#fbbf24; font-size:1rem; letter-spacing:2px; }

  .fb-item-date {
    font-size:0.72rem; color:var(--text-muted);
    font-family:"JetBrains Mono",monospace;
  }

  .fb-item-msg {
    color:var(--text-dim); font-size:0.88rem;
    line-height:1.7; font-style:italic;
    border-left:3px solid var(--accent);
    padding-left:12px;
  }

  .fb-empty {
    text-align:center; padding:40px;
    color:var(--text-muted); font-size:0.9rem;
  }

  @media (max-width:640px) {
    .admin-header { padding:12px 16px; }
    .admin-tabs { gap:2px; }
    .admin-tab { padding:7px 10px; font-size:0.78rem; }
  }
</style>

<script is:inline type="module">
  import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
  import { getAuth, RecaptchaVerifier, signInWithPhoneNumber } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-auth.js";

  const firebaseConfig = {
    apiKey: "AIzaSyCdRfvA6NWZ5-BNYanmZ9PW5yX5meFBMJ4",
    authDomain: "hakan-efe-portfolyo.firebaseapp.com",
    projectId: "hakan-efe-portfolyo",
    storageBucket: "hakan-efe-portfolyo.firebasestorage.app",
    messagingSenderId: "994387061513",
    appId: "1:994387061513:web:90aef3d4506717870f81d8",
  };

  const app = initializeApp(firebaseConfig);
  const auth = getAuth(app);
  auth.languageCode = "tr";

  const ADMIN_PASS = "hakanefe2026";
  const ADMIN_PHONE = "+905522861141";
  const FB_BASE = "https://firestore.googleapis.com/v1/projects/hakan-efe-portfolyo/databases/(default)/documents";

  let confirmationResult = null;

  // ── ŞİFRE KONTROLÜ ──────────────────────────────────────
  window.checkPass = function() {
    const pass = document.getElementById("input-pass").value;
    if (pass !== ADMIN_PASS) {
      document.getElementById("pass-error").style.display = "block";
      return;
    }
    document.getElementById("screen-pass").style.display = "none";
    document.getElementById("screen-sms").style.display = "flex";
    sendSMS();
  };

  // ── SMS GÖNDER ───────────────────────────────────────────
  async function sendSMS() {
    try {
      if (!window.recaptchaVerifier) {
        window.recaptchaVerifier = new RecaptchaVerifier(auth, "recaptcha-container", {
          size: "invisible",
          callback: () => {},
        });
      }
      confirmationResult = await signInWithPhoneNumber(auth, ADMIN_PHONE, window.recaptchaVerifier);
    } catch(e) {
      console.error(e);
      // reCAPTCHA sıfırla
      if (window.recaptchaVerifier) {
        window.recaptchaVerifier.clear();
        window.recaptchaVerifier = null;
      }
    }
  }

  window.resendSMS = function() {
    document.getElementById("input-code").value = "";
    document.getElementById("sms-error").style.display = "none";
    if (window.recaptchaVerifier) {
      window.recaptchaVerifier.clear();
      window.recaptchaVerifier = null;
    }
    sendSMS();
  };

  // ── SMS DOĞRULA ──────────────────────────────────────────
  window.verifySMS = async function() {
    const code = document.getElementById("input-code").value.trim();
    if (!code || code.length < 6) return;
    try {
      await confirmationResult.confirm(code);
      // Başarılı
      document.getElementById("screen-sms").style.display = "none";
      document.getElementById("screen-admin").style.display = "block";
      loadPosts();
    } catch {
      document.getElementById("sms-error").style.display = "block";
    }
  };

  // ── ÇIKIŞ ────────────────────────────────────────────────
  window.adminLogout = function() {
    auth.signOut();
    location.reload();
  };

  // ── TAB YÖNETİMİ ────────────────────────────────────────
  window.showTab = function(id) {
    document.querySelectorAll(".admin-tab-content").forEach(t => t.style.display = "none");
    document.querySelectorAll(".admin-tab").forEach(b => b.classList.remove("active"));
    document.getElementById(id).style.display = "block";
    const map = {"tab-write":"btn-write","tab-posts":"btn-posts","tab-feedback":"btn-feedback"};
    document.getElementById(map[id]).classList.add("active");
    if (id === "tab-posts") loadPosts();
    if (id === "tab-feedback") loadFeedback();
  };

  // ── YAZI YAYINLA ────────────────────────────────────────
  document.getElementById("post-body")?.addEventListener("input", function() {
    document.getElementById("char-count").textContent = this.value.length + " karakter";
  });

  window.publishPost = async function(e) {
    e.preventDefault();
    const btn = document.getElementById("publish-btn");
    btn.disabled = true; btn.textContent = "Yayınlanıyor...";
    document.getElementById("publish-success").style.display = "none";
    document.getElementById("publish-error").style.display = "none";

    try {
      await fetch(FB_BASE + "/blog", {
        method:"POST",
        headers:{"Content-Type":"application/json"},
        body: JSON.stringify({ fields: {
          title:  { stringValue: document.getElementById("post-title").value },
          tag:    { stringValue: document.getElementById("post-tag").value || "Genel" },
          body:   { stringValue: document.getElementById("post-body").value },
          author: { stringValue: "Hakan Efe" },
          date:   { stringValue: new Date().toISOString() },
        }})
      });
      document.getElementById("publish-success").style.display = "block";
      document.getElementById("post-form").reset();
      document.getElementById("char-count").textContent = "0 karakter";
    } catch {
      document.getElementById("publish-error").style.display = "block";
    } finally {
      btn.disabled = false; btn.textContent = "Yayınla 🚀";
    }
  };

  // ── YAZILARI LİSTELE ────────────────────────────────────
  async function loadPosts() {
    const list = document.getElementById("posts-list");
    list.innerHTML = "<p class='loading-p'>Yükleniyor...</p>";
    try {
      const res = await fetch(FB_BASE + "/blog?orderBy=date%20desc&pageSize=30");
      const data = await res.json();
      const docs = data.documents || [];
      if (!docs.length) { list.innerHTML = "<p class='loading-p'>Henüz yazı yok.</p>"; return; }
      list.innerHTML = docs.map(doc => {
        const f = doc.fields;
        const id = doc.name.split("/").pop();
        const date = new Date(f.date?.stringValue || "").toLocaleDateString("tr-TR");
        return `<div class="post-item">
          <div>
            <div class="post-item-title">${f.title?.stringValue || ""}</div>
            <div class="post-item-meta">${f.tag?.stringValue || "Genel"} · ${date}</div>
          </div>
          <button class="delete-btn" onclick="deletePost('${id}')">🗑 Sil</button>
        </div>`;
      }).join("");
    } catch {
      list.innerHTML = "<p style='color:#ef4444'>Yüklenemedi.</p>";
    }
  }
  window.loadPosts = loadPosts;

  window.deletePost = async function(id) {
    if (!confirm("Bu yazıyı silmek istediğinden emin misin?")) return;
    await fetch(FB_BASE + "/blog/" + id, { method:"DELETE" });
    loadPosts();
  };

  // ── YORUMLARI OKU ───────────────────────────────────────
  async function loadFeedback() {
    const list = document.getElementById("feedback-list");
    list.innerHTML = "<p class='loading-p'>Yorumlar yükleniyor...</p>";
    try {
      const res = await fetch(FB_BASE + "/feedback?orderBy=date%20desc&pageSize=50");
      const data = await res.json();
      const docs = data.documents || [];

      if (!docs.length) {
        list.innerHTML = "<div class='fb-empty'>💬 Henüz yorum yok.</div>";
        return;
      }

      list.innerHTML = docs.map(doc => {
        const f = doc.fields;
        const stars = parseInt(f.stars?.integerValue || "5");
        const starsHtml = "★".repeat(stars) + "☆".repeat(5 - stars);
        const date = new Date(f.date?.stringValue || "").toLocaleDateString("tr-TR", {
          day:"numeric", month:"long", year:"numeric", hour:"2-digit", minute:"2-digit"
        });
        return `<div class="feedback-item">
          <div class="fb-item-header">
            <div>
              <div class="fb-item-name">${f.name?.stringValue || "Anonim"}</div>
              ${f.email?.stringValue ? `<div class="fb-item-email">${f.email.stringValue}</div>` : ""}
            </div>
            <div style="text-align:right">
              <div class="fb-stars-display">${starsHtml}</div>
              <div class="fb-item-date">${date}</div>
            </div>
          </div>
          <div class="fb-item-msg">${f.message?.stringValue || ""}</div>
        </div>`;
      }).join("");
    } catch {
      list.innerHTML = "<p style='color:#ef4444'>Yorumlar yüklenemedi.</p>";
    }
  }
  window.loadFeedback = loadFeedback;
</script>
