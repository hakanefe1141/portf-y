---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Admin Panel | Hakan Efe">

<!-- Firebase SDKs -->
<script is:inline src="https://www.gstatic.com/firebasejs/10.12.0/firebase-app-compat.js"></script>
<script is:inline src="https://www.gstatic.com/firebasejs/10.12.0/firebase-auth-compat.js"></script>
<script is:inline src="https://www.gstatic.com/firebasejs/10.12.0/firebase-storage-compat.js"></script>

<div class="admin-page">

  <!-- 1. ŞİFRE EKRANI -->
  <div id="screen-pass">
    <div class="login-box">
      <div class="login-icon">🔐</div>
      <h1>Admin Girişi</h1>
      <p>Bu sayfa sadece Hakan Efe tarafından kullanılabilir.</p>
      <input type="password" id="input-pass" placeholder="Şifre"
        onkeydown="if(event.key==='Enter') checkPass()" />
      <button id="pass-btn" onclick="checkPass()">Giriş Yap →</button>
      <p id="pass-error" class="error-msg" style="display:none">Yanlış şifre!</p>
    </div>
  </div>

  <!-- 2. SMS DOĞRULAMA EKRANI -->
  <div id="screen-otp" style="display:none">
    <div class="login-box">
      <div class="login-icon">📱</div>
      <h1>SMS Doğrulama</h1>
      <p id="otp-desc">+90 552 *** ** 41 numarasına gönderilen kodu gir.</p>
      <input type="text" id="input-otp" placeholder="_ _ _ _ _ _"
        maxlength="6" inputmode="numeric" autocomplete="one-time-code"
        onkeydown="if(event.key==='Enter') verifyOtp()" />
      <button id="otp-btn" onclick="verifyOtp()">Doğrula →</button>
      <button class="resend-btn" id="resend-btn" onclick="resendOtp()">↺ Kodu Tekrar Gönder</button>
      <p id="otp-error" class="error-msg" style="display:none">Hatalı kod, tekrar dene.</p>
      <p id="otp-timer" class="timer-msg"></p>
    </div>
  </div>

  <!-- reCAPTCHA (Firebase için gerekli, görünmez) -->
  <div id="recaptcha-container"></div>

  <!-- 3. ADMIN PANELİ -->
  <div id="screen-admin" style="display:none">
    <header class="admin-header">
      <div class="admin-logo">⚙️ Admin Panel</div>
      <div class="admin-tabs">
        <button onclick="showTab('tab-write')" class="admin-tab active" id="btn-write">✏️ Yazı Yaz</button>
        <button onclick="showTab('tab-posts')" class="admin-tab" id="btn-posts">📋 Yazılarım</button>
        <button onclick="showTab('tab-feedback')" class="admin-tab" id="btn-feedback">💬 Yorumlar</button>
        <button onclick="showTab('tab-cv')" class="admin-tab" id="btn-cv">📄 CV</button>
        <button onclick="showTab('tab-exp')" class="admin-tab" id="btn-exp">💼 Deneyim</button>
        <button onclick="showTab('tab-ref')" class="admin-tab" id="btn-ref">👥 Referanslar</button>
      </div>
      <button onclick="adminLogout()" class="logout-btn">Çıkış</button>
    </header>

    <main class="admin-main container">

      <!-- YENİ YAZI -->
      <div id="tab-write" class="admin-tab-content">
        <div class="admin-card">
          <h2>Yeni Blog Yazısı</h2>
          <form id="post-form" onsubmit="publishPost(event)">
            <input type="text" id="post-title" placeholder="Başlık *" required />
            <input type="text" id="post-tag" placeholder="Etiket (örn: E-Öğrenme, ADDIE, LMS)" />
            <textarea id="post-body" rows="16" placeholder="Yazı içeriği *" required></textarea>
            <div class="form-footer">
              <span id="char-count" class="char-count">0 karakter</span>
              <button type="submit" id="publish-btn">Yayınla 🚀</button>
            </div>
          </form>
          <div id="publish-success" class="success-toast" style="display:none">✅ Yazı yayınlandı!</div>
          <div id="publish-error" class="error-toast" style="display:none">❌ Hata oluştu.</div>
        </div>
      </div>

      <!-- YAZILARI -->
      <div id="tab-posts" class="admin-tab-content" style="display:none">
        <div class="admin-card">
          <div class="card-header">
            <h2>Yazılarım</h2>
            <button onclick="loadPosts()" class="refresh-btn">↺ Yenile</button>
          </div>
          <div id="posts-list"><p class="loading-p">Yükleniyor...</p></div>
        </div>
      </div>

      <!-- YORUMLAR -->
      <div id="tab-feedback" class="admin-tab-content" style="display:none">
        <div class="admin-card">
          <div class="card-header">
            <h2>Ziyaretçi Yorumları</h2>
            <button onclick="loadFeedback()" class="refresh-btn">↺ Yenile</button>
          </div>
          <div id="feedback-list"><p class="loading-p">Yükleniyor...</p></div>
        </div>
      </div>

      <!-- CV YÖNETİMİ -->
      <div id="tab-cv" class="admin-tab-content" style="display:none">
        <div class="admin-card">
          <h2>📄 CV Yönetimi</h2>
          <div id="cv-current" class="cv-current-info">
            <p class="loading-p">Mevcut CV bilgisi yükleniyor...</p>
          </div>
          <div class="cv-upload-section">
            <label class="cv-upload-label" for="cv-file-input">
              <span>📎 PDF Seç</span>
              <input type="file" id="cv-file-input" accept=".pdf" onchange="onCVFileSelect(this)" />
            </label>
            <span id="cv-file-name" class="cv-file-name">Dosya seçilmedi</span>
            <button id="cv-upload-btn" onclick="uploadCV()" disabled class="upload-btn">Yükle & Güncelle</button>
          </div>
          <div id="cv-upload-status"></div>
        </div>
      </div>

      <!-- DENEYİM YÖNETİMİ -->
      <div id="tab-exp" class="admin-tab-content" style="display:none">
        <div class="admin-card">
          <div class="card-header">
            <h2>💼 İş Deneyimi</h2>
            <button onclick="toggleExpForm()" class="refresh-btn" id="add-exp-btn">+ Yeni Ekle</button>
          </div>

          <!-- Yeni deneyim formu -->
          <div id="exp-form" style="display:none" class="exp-form-wrap">
            <input type="text" id="exp-title" placeholder="Ünvan *" />
            <input type="text" id="exp-company" placeholder="Şirket / Kurum *" />
            <input type="text" id="exp-location" placeholder="Şehir (örn: İstanbul)" />
            <div class="exp-date-row">
              <input type="text" id="exp-start" placeholder="Başlangıç (örn: 2024)" />
              <span>—</span>
              <input type="text" id="exp-end" placeholder="Bitiş (örn: 2025 veya Günümüz)" />
            </div>
            <textarea id="exp-bullets" rows="4" placeholder="Görevler (her satıra bir madde)"></textarea>
            <input type="text" id="exp-tags" placeholder="Etiketler (virgülle ayır: React, LMS)" />
            <div class="form-footer">
              <button onclick="toggleExpForm()" class="cancel-btn">İptal</button>
              <button onclick="saveExperience()" class="upload-btn">💾 Kaydet</button>
            </div>
            <div id="exp-save-status"></div>
          </div>

          <div id="exp-list"><p class="loading-p">Yükleniyor...</p></div>
        </div>
      </div>

      <!-- REFERANSLAR YÖNETİMİ -->
      <div id="tab-ref" class="admin-tab-content" style="display:none">
        <div class="admin-card">
          <div class="card-header">
            <h2>👥 Referanslar</h2>
            <button onclick="toggleRefForm()" class="refresh-btn" id="add-ref-btn">+ Yeni Ekle</button>
          </div>

          <!-- Yeni referans formu -->
          <div id="ref-form" style="display:none" class="exp-form-wrap">
            <input type="text" id="ref-name" placeholder="Ad Soyad *" />
            <input type="text" id="ref-title" placeholder="Ünvan / Pozisyon *" />
            <input type="text" id="ref-org" placeholder="Kurum / Şirket" />
            <input type="text" id="ref-relation" placeholder="İlişki (örn: Doğrudan yöneticim, Çalışma arkadaşım)" />
            <input type="text" id="ref-phone" placeholder="Telefon (sadece admin görebilir)" />
            <input type="email" id="ref-email" placeholder="E-posta (sadece admin görebilir)" />
            <textarea id="ref-note" rows="3" placeholder="Not (opsiyonel)"></textarea>
            <div class="form-footer">
              <button onclick="toggleRefForm()" class="cancel-btn">İptal</button>
              <button onclick="saveReference()" class="upload-btn">💾 Kaydet</button>
            </div>
            <div id="ref-save-status"></div>
          </div>

          <div id="ref-list"><p class="loading-p">Yükleniyor...</p></div>
        </div>
      </div>

    </main>
  </div>
</div>
</Layout>

<style>
  .admin-page { min-height:100vh; background:var(--bg); color:var(--text); font-family:"Inter",sans-serif; }
  .container { max-width:860px; margin:0 auto; padding:0 24px; }

  #screen-pass, #screen-otp {
    min-height:100vh;
    display:flex; align-items:center; justify-content:center;
  }

  .login-box {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 48px 40px;
    width: min(420px, 92vw);
    text-align: center;
    display: flex; flex-direction: column; gap: 14px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.25);
  }

  .login-icon { font-size: 3rem; }
  .login-box h1 { font-size:1.6rem; font-weight:700; }
  .login-box > p { color:var(--text-muted); font-size:0.9rem; }

  .login-box input {
    width:100%; background:var(--bg);
    border:1px solid var(--border); border-radius:10px;
    padding:14px 16px; color:var(--text);
    font-size:1.15rem; font-family:"JetBrains Mono",monospace;
    outline:none; text-align:center;
    letter-spacing: 0.25em;
    transition:border-color 0.2s;
  }
  .login-box input:focus { border-color:var(--accent); }

  .login-box button {
    background: linear-gradient(135deg, var(--accent), #c084fc);
    color:white; border:none; border-radius:10px;
    padding:13px; font-weight:700; font-size:0.95rem;
    cursor:pointer; font-family:"Inter",sans-serif;
    transition:opacity 0.2s;
  }
  .login-box button:hover { opacity:0.88; }
  .login-box button:disabled { opacity:0.5; cursor:not-allowed; }

  .resend-btn {
    background: none !important;
    border: 1px solid var(--border) !important;
    color: var(--text-muted) !important;
    font-size: 0.82rem !important;
    padding: 9px !important;
  }
  .resend-btn:hover { border-color: var(--accent) !important; color: var(--accent-light) !important; opacity:1 !important; }

  .error-msg { color:#ef4444; font-size:0.85rem; }
  .timer-msg { color:var(--text-muted); font-size:0.78rem; font-family:"JetBrains Mono",monospace; }

  #recaptcha-container { position:fixed; bottom:0; right:0; z-index:9999; }

  .admin-header {
    display:flex; align-items:center; gap:12px;
    padding:14px 28px; background:var(--bg-card);
    border-bottom:1px solid var(--border);
    position:sticky; top:0; z-index:100; flex-wrap:wrap;
  }
  .admin-logo { font-weight:700; font-size:1rem; flex-shrink:0; }
  .admin-tabs { display:flex; gap:4px; flex:1; }
  .admin-tab {
    background:none; border:none; border-radius:8px;
    padding:8px 16px; font-size:0.85rem; font-weight:500;
    cursor:pointer; color:var(--text-muted); font-family:"Inter",sans-serif;
    transition:background 0.2s, color 0.2s;
  }
  .admin-tab:hover { background:var(--bg); color:var(--text); }
  .admin-tab.active { background:var(--accent-glow); color:var(--accent-light); border:1px solid rgba(124,58,237,0.3); }
  .logout-btn {
    background:rgba(239,68,68,0.08); border:1px solid rgba(239,68,68,0.25);
    color:#ef4444; border-radius:8px; padding:7px 16px; font-size:0.82rem;
    cursor:pointer; font-family:"Inter",sans-serif; margin-left:auto;
  }
  .admin-main { padding:32px 24px 60px; }
  .admin-card { background:var(--bg-card); border:1px solid var(--border); border-radius:14px; padding:28px; }
  .admin-card h2 { font-size:1.1rem; font-weight:700; margin-bottom:20px; }
  .card-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:20px; }
  .card-header h2 { margin-bottom:0; }
  .refresh-btn { background:none; border:1px solid var(--border); color:var(--text-muted); border-radius:6px; padding:5px 14px; font-size:0.8rem; cursor:pointer; font-family:"Inter",sans-serif; }
  #post-form { display:flex; flex-direction:column; gap:12px; }
  #post-form input, #post-form textarea {
    background:var(--bg); border:1px solid var(--border); border-radius:10px;
    padding:12px 16px; color:var(--text); font-size:0.9rem;
    font-family:"Inter",sans-serif; outline:none; resize:vertical;
    letter-spacing: normal;
    transition:border-color 0.2s;
  }
  #post-form input:focus, #post-form textarea:focus { border-color:var(--accent); }
  .form-footer { display:flex; align-items:center; justify-content:space-between; }
  .char-count { font-size:0.75rem; color:var(--text-muted); font-family:"JetBrains Mono",monospace; }
  #publish-btn { background:linear-gradient(135deg,var(--accent),#c084fc); color:white; border:none; border-radius:8px; padding:10px 24px; font-weight:700; font-size:0.9rem; cursor:pointer; font-family:"Inter",sans-serif; }
  #publish-btn:disabled { opacity:0.5; cursor:not-allowed; }
  .success-toast { color:#22c55e; font-weight:600; font-size:0.9rem; margin-top:8px; }
  .error-toast { color:#ef4444; font-weight:600; font-size:0.9rem; margin-top:8px; }
  .loading-p { color:var(--text-muted); font-size:0.9rem; }
  .post-item { display:flex; justify-content:space-between; align-items:flex-start; padding:18px 0; border-bottom:1px solid rgba(255,255,255,0.08); gap:12px; }
  .post-item:last-child { border-bottom:none; }
  .post-item-title { font-weight:600; font-size:0.9rem; margin-bottom:4px; }
  .post-item-meta { font-size:0.75rem; color:var(--text-muted); font-family:"JetBrains Mono",monospace; }
  .delete-btn { background:rgba(239,68,68,0.08); border:1px solid rgba(239,68,68,0.2); color:#ef4444; border-radius:6px; padding:5px 12px; font-size:0.78rem; cursor:pointer; white-space:nowrap; flex-shrink:0; }
  .feedback-item { background:var(--bg); border:1px solid rgba(255,255,255,0.08); border-radius:12px; padding:18px; margin-bottom:10px; }
  .fb-item-header { display:flex; align-items:flex-start; justify-content:space-between; margin-bottom:10px; flex-wrap:wrap; gap:8px; }
  .fb-item-name { font-weight:600; font-size:0.95rem; }
  .fb-item-email { font-size:0.78rem; color:var(--text-muted); }
  .fb-stars-display { color:#fbbf24; font-size:1rem; }
  .fb-item-date { font-size:0.72rem; color:var(--text-muted); font-family:"JetBrains Mono",monospace; }
  .fb-item-msg { color:var(--text-dim); font-size:0.88rem; line-height:1.7; font-style:italic; border-left:3px solid var(--accent); padding-left:12px; }
  .fb-empty { text-align:center; padding:40px; color:var(--text-muted); font-size:0.9rem; }
  /* CV */
  .cv-current-info { background:var(--bg); border:1px solid var(--border); border-radius:10px; padding:16px; margin-bottom:16px; font-size:0.88rem; }
  .cv-upload-section { display:flex; align-items:center; gap:12px; flex-wrap:wrap; margin-bottom:12px; }
  .cv-upload-label { display:inline-flex; align-items:center; gap:8px; background:var(--bg); border:1px solid var(--border); border-radius:8px; padding:9px 16px; cursor:pointer; font-size:0.85rem; transition:border-color 0.2s; }
  .cv-upload-label:hover { border-color:var(--accent); }
  .cv-upload-label input { display:none; }
  .cv-file-name { font-size:0.8rem; color:var(--text-muted); font-family:"JetBrains Mono",monospace; }
  .upload-btn { background:linear-gradient(135deg,var(--accent),#c084fc); color:white; border:none; border-radius:8px; padding:9px 20px; font-weight:700; font-size:0.88rem; cursor:pointer; font-family:"Inter",sans-serif; }
  .upload-btn:disabled { opacity:0.4; cursor:not-allowed; }

  /* DENEYIM */
  .exp-form-wrap { background:var(--bg); border:1px solid var(--border); border-radius:10px; padding:20px; margin-bottom:20px; display:flex; flex-direction:column; gap:10px; }
  .exp-form-wrap input, .exp-form-wrap textarea {
    background:var(--bg-card); border:1px solid var(--border); border-radius:8px;
    padding:10px 14px; color:var(--text); font-size:0.88rem;
    font-family:"Inter",sans-serif; outline:none; resize:vertical;
    transition:border-color 0.2s;
  }
  .exp-form-wrap input:focus, .exp-form-wrap textarea:focus { border-color:var(--accent); }
  .exp-date-row { display:flex; align-items:center; gap:8px; }
  .exp-date-row input { flex:1; }
  .exp-date-row span { color:var(--text-muted); }
  .cancel-btn { background:none; border:1px solid var(--border); color:var(--text-muted); border-radius:8px; padding:9px 20px; font-size:0.88rem; cursor:pointer; font-family:"Inter",sans-serif; }
  .exp-item { display:flex; justify-content:space-between; align-items:flex-start; padding:18px 0; border-bottom:1px solid rgba(255,255,255,0.08); gap:12px; }
  .exp-item:last-child { border-bottom:none; }
  .exp-item-title { font-weight:700; font-size:0.9rem; }
  .exp-item-company { font-size:0.82rem; color:var(--accent-light); margin:2px 0; }
  .exp-item-date { font-size:0.75rem; color:var(--text-muted); font-family:"JetBrains Mono",monospace; }

  /* REFERANSLAR */
  .ref-item { display:flex; justify-content:space-between; align-items:flex-start; padding:18px 0; border-bottom:1px solid rgba(255,255,255,0.08); gap:12px; }
  .ref-item:last-child { border-bottom:none; }
  .ref-item-name { font-weight:700; font-size:0.95rem; }
  .ref-item-title { font-size:0.83rem; color:var(--accent-light); margin:2px 0; }
  .ref-item-rel { font-size:0.78rem; color:var(--text-muted); font-style:italic; margin-top:2px; }
  .ref-item-contact { font-size:0.78rem; color:var(--text-muted); font-family:"JetBrains Mono",monospace; margin-top:4px; }
  .ref-item-note { font-size:0.78rem; color:var(--text-dim); margin-top:4px; }

  @media (max-width:640px) {
    .admin-tabs { gap:2px; flex-wrap:wrap; }
    .admin-tab { padding:7px 10px; font-size:0.78rem; }
  }
</style>

<script is:inline>
  // ─── Firebase Yapılandırması ───────────────────────────────
  // Firebase Console → Project Settings → General → Your apps → apiKey
  const FIREBASE_CONFIG = {
    apiKey:            "AIzaSyCdRfvA6NWZ5-BNYanmZ9PW5yX5meFBMJ4",
    authDomain:        "hakan-efe-portfolyo.firebaseapp.com",
    projectId:         "hakan-efe-portfolyo",
    storageBucket:     "hakan-efe-portfolyo.firebasestorage.app",
    messagingSenderId: "994387061513",
    appId:             "1:994387061513:web:90aef3d4506717870f81d8",
  };

  const ADMIN_PASS  = "hakanefe2026";
  const ADMIN_PHONE = "+905522861141";
  const FB_BASE     = "https://firestore.googleapis.com/v1/projects/hakan-efe-portfolyo/databases/(default)/documents";

  // ─── Firebase başlat ──────────────────────────────────────
  let auth, confirmResult, recaptchaVerifier;

  function initFirebase() {
    if (!firebase.apps.length) firebase.initializeApp(FIREBASE_CONFIG);
    auth = firebase.auth();
    auth.languageCode = "tr";
  }

  // ─── Oturum kontrolü — her zaman tam SMS doğrulaması gerekir ──
  // localStorage bypass kaldırıldı, güvenlik artırıldı

  // ─── 1. Şifre kontrolü ────────────────────────────────────
  function resetRecaptcha() {
    try { if (recaptchaVerifier) recaptchaVerifier.clear(); } catch(_) {}
    recaptchaVerifier = null;
    // DOM elementini de temizle
    const el = document.getElementById("recaptcha-container");
    if (el) el.innerHTML = "";
  }

  async function sendSms() {
    resetRecaptcha();
    recaptchaVerifier = new firebase.auth.RecaptchaVerifier("recaptcha-container", {
      size: "invisible",
      callback: () => {},
    });
    await recaptchaVerifier.render();
    return auth.signInWithPhoneNumber(ADMIN_PHONE, recaptchaVerifier);
  }

  window.checkPass = async function() {
    const pass = document.getElementById("input-pass").value;
    const btn  = document.getElementById("pass-btn");
    const err  = document.getElementById("pass-error");

    if (pass !== ADMIN_PASS) {
      err.style.display = "block";
      return;
    }
    err.style.display = "none";
    // SMS geçici olarak devre dışı — sadece şifreyle giriş
    initFirebase();
    showPanel();
  };

  // ─── 2. OTP doğrulama ─────────────────────────────────────
  window.verifyOtp = async function() {
    const code = document.getElementById("input-otp").value.trim();
    const btn  = document.getElementById("otp-btn");
    const err  = document.getElementById("otp-error");

    if (code.length !== 6) { err.style.display = "block"; return; }

    btn.disabled = true;
    btn.textContent = "Doğrulanıyor...";
    err.style.display = "none";

    try {
      await confirmResult.confirm(code);
      localStorage.setItem("admin_auth", "1");
      showPanel();
    } catch(e) {
      btn.disabled = false;
      btn.textContent = "Doğrula →";
      err.style.display = "block";
    }
  };

  // ─── 3. Kodu yeniden gönder ───────────────────────────────
  window.resendOtp = async function() {
    const btn = document.getElementById("resend-btn");
    btn.disabled = true;
    try {
      confirmResult = await sendSms();
      document.getElementById("otp-error").style.display = "none";
      document.getElementById("input-otp").value = "";
      startTimer(120);
    } catch(e) {
      btn.disabled = false;
    }
  };

  // ─── Geri sayım sayacı ────────────────────────────────────
  let timerInterval;
  function startTimer(seconds) {
    clearInterval(timerInterval);
    const timerEl  = document.getElementById("otp-timer");
    const resendBtn = document.getElementById("resend-btn");
    resendBtn.disabled = true;
    let remaining = seconds;
    timerEl.textContent = `Kod ${remaining}s içinde sona erer`;
    timerInterval = setInterval(() => {
      remaining--;
      if (remaining <= 0) {
        clearInterval(timerInterval);
        timerEl.textContent = "Kod süresi doldu.";
        resendBtn.disabled = false;
      } else {
        timerEl.textContent = `Kod ${remaining}s içinde sona erer`;
      }
    }, 1000);
  }

  // ─── Admin paneli aç ──────────────────────────────────────
  function showPanel() {
    document.getElementById("screen-pass").style.display = "none";
    document.getElementById("screen-otp").style.display  = "none";
    document.getElementById("screen-admin").style.display = "block";
    loadPosts();
  }

  window.adminLogout = function() {
    localStorage.removeItem("admin_auth");
    if (auth) auth.signOut().catch(()=>{});
    location.reload();
  };

  window.showTab = function(id) {
    document.querySelectorAll(".admin-tab-content").forEach(t => t.style.display = "none");
    document.querySelectorAll(".admin-tab").forEach(b => b.classList.remove("active"));
    document.getElementById(id).style.display = "block";
    const map = {"tab-write":"btn-write","tab-posts":"btn-posts","tab-feedback":"btn-feedback","tab-cv":"btn-cv","tab-exp":"btn-exp","tab-ref":"btn-ref"};
    document.getElementById(map[id]).classList.add("active");
    if (id === "tab-posts")    loadPosts();
    if (id === "tab-feedback") loadFeedback();
    if (id === "tab-cv")       loadCVInfo();
    if (id === "tab-exp")      loadExperiences();
    if (id === "tab-ref")      loadReferences();
  };

  document.getElementById("post-body")?.addEventListener("input", function() {
    document.getElementById("char-count").textContent = this.value.length + " karakter";
  });

  // ─── Blog yayınla ─────────────────────────────────────────
  window.publishPost = async function(e) {
    e.preventDefault();
    const btn = document.getElementById("publish-btn");
    btn.disabled = true; btn.textContent = "Yayınlanıyor...";
    document.getElementById("publish-success").style.display = "none";
    document.getElementById("publish-error").style.display   = "none";
    try {
      await fetch(FB_BASE + "/blog", {
        method:"POST", headers:{"Content-Type":"application/json"},
        body: JSON.stringify({ fields: {
          title:  { stringValue: document.getElementById("post-title").value },
          tag:    { stringValue: document.getElementById("post-tag").value || "Genel" },
          body:   { stringValue: document.getElementById("post-body").value },
          author: { stringValue: "Hakan Efe" },
          date:   { stringValue: new Date().toISOString() },
        }})
      });
      document.getElementById("publish-success").style.display = "block";
      document.getElementById("post-form").reset();
      document.getElementById("char-count").textContent = "0 karakter";
    } catch {
      document.getElementById("publish-error").style.display = "block";
    } finally {
      btn.disabled = false; btn.textContent = "Yayınla 🚀";
    }
  };

  // ─── Yazıları yükle ───────────────────────────────────────
  async function loadPosts() {
    const list = document.getElementById("posts-list");
    list.innerHTML = "<p class='loading-p'>Yükleniyor...</p>";
    try {
      const res = await fetch(
        "https://firestore.googleapis.com/v1/projects/hakan-efe-portfolyo/databases/(default)/documents:runQuery",
        { method:"POST", headers:{"Content-Type":"application/json"},
          body: JSON.stringify({ structuredQuery: {
            from:[{collectionId:"blog"}],
            orderBy:[{field:{fieldPath:"date"},direction:"DESCENDING"}], limit:30
          }})
        }
      );
      const rows = await res.json();
      const docs = rows.filter(r => r.document).map(r => r.document);
      if (!docs.length) { list.innerHTML = "<p class='loading-p'>Henüz yazı yok.</p>"; return; }
      list.innerHTML = docs.map(doc => {
        const f = doc.fields;
        const id = doc.name.split("/").pop();
        const date = new Date(f.date?.stringValue || "").toLocaleDateString("tr-TR");
        return `<div class="post-item">
          <div>
            <div class="post-item-title">${f.title?.stringValue || ""}</div>
            <div class="post-item-meta">${f.tag?.stringValue || "Genel"} · ${date}</div>
          </div>
          <button class="delete-btn" onclick="deletePost('${id}')">🗑 Sil</button>
        </div>`;
      }).join("");
    } catch(e) { list.innerHTML = `<p style='color:#ef4444'>Yüklenemedi: ${e.message}</p>`; }
  }
  window.loadPosts = loadPosts;

  window.deletePost = async function(id) {
    if (!confirm("Bu yazıyı silmek istediğinden emin misin?")) return;
    await fetch(FB_BASE + "/blog/" + id, { method:"DELETE" });
    loadPosts();
  };

  // ─── Yorumları yükle ──────────────────────────────────────
  async function loadFeedback() {
    const list = document.getElementById("feedback-list");
    list.innerHTML = "<p class='loading-p'>Yorumlar yükleniyor...</p>";
    try {
      const res = await fetch(
        "https://firestore.googleapis.com/v1/projects/hakan-efe-portfolyo/databases/(default)/documents:runQuery",
        { method:"POST", headers:{"Content-Type":"application/json"},
          body: JSON.stringify({ structuredQuery: {
            from:[{collectionId:"feedback"}],
            orderBy:[{field:{fieldPath:"date"},direction:"DESCENDING"}], limit:50
          }})
        }
      );
      if (!res.ok) {
        const err = await res.json().catch(()=>({}));
        list.innerHTML = res.status===403
          ? `<div class='fb-empty' style='color:#ef4444'>🔒 İzin hatası — <code>firebase deploy --only firestore:rules</code> çalıştır.</div>`
          : `<div class='fb-empty' style='color:#ef4444'>Hata ${res.status}</div>`;
        return;
      }
      const rows = await res.json();
      const docs = rows.filter(r => r.document).map(r => r.document);
      if (!docs.length) { list.innerHTML = "<div class='fb-empty'>💬 Henüz yorum yok.</div>"; return; }
      list.innerHTML = docs.map(doc => {
        const f = doc.fields;
        const stars = parseInt(f.stars?.integerValue || "5");
        const starsHtml = "★".repeat(Math.min(5,stars)) + "☆".repeat(Math.max(0,5-stars));
        const rawDate = f.date?.stringValue || "";
        const date = rawDate ? new Date(rawDate).toLocaleDateString("tr-TR",{day:"numeric",month:"long",year:"numeric"}) : "—";
        return `<div class="feedback-item">
          <div class="fb-item-header">
            <div>
              <div class="fb-item-name">${f.name?.stringValue||"Anonim"}</div>
              ${f.email?.stringValue?`<div class="fb-item-email">${f.email.stringValue}</div>`:""}
            </div>
            <div style="text-align:right">
              <div class="fb-stars-display">${starsHtml}</div>
              <div class="fb-item-date">${date}</div>
            </div>
          </div>
          <div class="fb-item-msg">${f.message?.stringValue||""}</div>
        </div>`;
      }).join("");
    } catch(e) { list.innerHTML = `<p style='color:#ef4444'>Hata: ${e.message}</p>`; }
  }
  window.loadFeedback = loadFeedback;

  // ─── CV Yönetimi ──────────────────────────────────────────
  async function loadCVInfo() {
    const el = document.getElementById("cv-current");
    try {
      const res = await fetch(FB_BASE + "/settings/cv");
      if (res.ok) {
        const data = await res.json();
        const f = data.fields || {};
        const url = f.url?.stringValue || "";
        const name = f.name?.stringValue || "CV";
        const date = f.uploadedAt?.stringValue ? new Date(f.uploadedAt.stringValue).toLocaleDateString("tr-TR") : "—";
        el.innerHTML = url
          ? `<p>📄 <strong>${name}</strong> · Yüklenme: ${date}</p><a href="${url}" target="_blank" style="color:var(--accent-light);font-size:0.82rem">Mevcut CV'yi Görüntüle →</a>`
          : `<p style="color:var(--text-muted)">Henüz CV yüklenmedi.</p>`;
      } else {
        el.innerHTML = `<p style="color:var(--text-muted)">Henüz CV yüklenmedi.</p>`;
      }
    } catch {
      el.innerHTML = `<p style="color:var(--text-muted)">Bilgi alınamadı.</p>`;
    }
  }

  window.onCVFileSelect = function(input) {
    const file = input.files[0];
    document.getElementById("cv-file-name").textContent = file ? file.name : "Dosya seçilmedi";
    document.getElementById("cv-upload-btn").disabled = !file;
  };

  window.uploadCV = async function() {
    const input = document.getElementById("cv-file-input");
    const file = input.files[0];
    if (!file) return;
    const btn = document.getElementById("cv-upload-btn");
    const status = document.getElementById("cv-upload-status");
    btn.disabled = true; btn.textContent = "Yükleniyor...";
    status.innerHTML = "";
    try {
      const storage = firebase.storage();
      const ref = storage.ref("cv/HakanEfe_CV.pdf");
      await ref.put(file);
      const url = await ref.getDownloadURL();
      await fetch(FB_BASE + "/settings/cv", {
        method: "PATCH",
        headers: {"Content-Type":"application/json"},
        body: JSON.stringify({ fields: {
          url:        { stringValue: url },
          name:       { stringValue: file.name },
          uploadedAt: { stringValue: new Date().toISOString() },
        }})
      });
      status.innerHTML = `<p style="color:#22c55e;margin-top:8px">✅ CV güncellendi!</p>`;
      loadCVInfo();
      input.value = "";
      document.getElementById("cv-file-name").textContent = "Dosya seçilmedi";
    } catch(e) {
      status.innerHTML = `<p style="color:#ef4444;margin-top:8px">❌ Hata: ${e.message}</p>`;
    } finally {
      btn.disabled = false; btn.textContent = "Yükle & Güncelle";
    }
  };

  // ─── Deneyim Yönetimi ─────────────────────────────────────
  window.toggleExpForm = function() {
    const form = document.getElementById("exp-form");
    const btn  = document.getElementById("add-exp-btn");
    const visible = form.style.display !== "none";
    form.style.display = visible ? "none" : "block";
    btn.textContent = visible ? "+ Yeni Ekle" : "İptal";
    if (!visible) {
      ["exp-title","exp-company","exp-location","exp-start","exp-end","exp-bullets","exp-tags"].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.value = "";
      });
      document.getElementById("exp-save-status").innerHTML = "";
    }
  };

  window.saveExperience = async function() {
    const title   = document.getElementById("exp-title").value.trim();
    const company = document.getElementById("exp-company").value.trim();
    if (!title || !company) { alert("Ünvan ve şirket zorunlu!"); return; }
    const location = document.getElementById("exp-location").value.trim();
    const start    = document.getElementById("exp-start").value.trim();
    const end      = document.getElementById("exp-end").value.trim();
    const bulletsRaw = document.getElementById("exp-bullets").value.trim();
    const bullets  = bulletsRaw ? bulletsRaw.split("\n").filter(b => b.trim()) : [];
    const tagsRaw  = document.getElementById("exp-tags").value.trim();
    const tags     = tagsRaw ? tagsRaw.split(",").map(t => t.trim()).filter(Boolean) : [];
    const status   = document.getElementById("exp-save-status");
    status.innerHTML = "";
    try {
      await fetch(FB_BASE + "/experience", {
        method: "POST",
        headers: {"Content-Type":"application/json"},
        body: JSON.stringify({ fields: {
          title:    { stringValue: title },
          company:  { stringValue: company },
          location: { stringValue: location },
          startDate:{ stringValue: start },
          endDate:  { stringValue: end },
          bullets:  { arrayValue: { values: bullets.map(b => ({ stringValue: b })) }},
          tags:     { arrayValue: { values: tags.map(t => ({ stringValue: t })) }},
          createdAt:{ stringValue: new Date().toISOString() },
        }})
      });
      status.innerHTML = `<p style="color:#22c55e;margin-top:8px">✅ Kaydedildi!</p>`;
      setTimeout(() => { toggleExpForm(); loadExperiences(); }, 800);
    } catch(e) {
      status.innerHTML = `<p style="color:#ef4444;margin-top:8px">❌ Hata: ${e.message}</p>`;
    }
  };

  async function loadExperiences() {
    const list = document.getElementById("exp-list");
    list.innerHTML = "<p class='loading-p'>Yükleniyor...</p>";
    try {
      const res = await fetch(
        "https://firestore.googleapis.com/v1/projects/hakan-efe-portfolyo/databases/(default)/documents:runQuery",
        { method:"POST", headers:{"Content-Type":"application/json"},
          body: JSON.stringify({ structuredQuery: {
            from:[{collectionId:"experience"}],
            orderBy:[{field:{fieldPath:"createdAt"},direction:"DESCENDING"}], limit:20
          }})
        }
      );
      const rows = await res.json();
      const docs = rows.filter(r => r.document).map(r => r.document);
      if (!docs.length) { list.innerHTML = "<p class='loading-p'>Henüz deneyim eklenmedi.</p>"; return; }
      list.innerHTML = docs.map(doc => {
        const f  = doc.fields;
        const id = doc.name.split("/").pop();
        const tags = (f.tags?.arrayValue?.values || []).map(v => v.stringValue).join(", ");
        const date = `${f.startDate?.stringValue || ""} — ${f.endDate?.stringValue || ""}`;
        return `<div class="exp-item">
          <div>
            <div class="exp-item-title">${f.title?.stringValue || ""}</div>
            <div class="exp-item-company">${f.company?.stringValue || ""} ${f.location?.stringValue ? `· ${f.location.stringValue}` : ""}</div>
            <div class="exp-item-date">${date}</div>
            ${tags ? `<div style="font-size:0.75rem;color:var(--text-muted);margin-top:4px">${tags}</div>` : ""}
          </div>
          <button class="delete-btn" onclick="deleteExperience('${id}')">🗑 Sil</button>
        </div>`;
      }).join("");
    } catch(e) {
      list.innerHTML = `<p style='color:#ef4444'>Hata: ${e.message}</p>`;
    }
  }
  window.loadExperiences = loadExperiences;

  window.deleteExperience = async function(id) {
    if (!confirm("Bu deneyimi silmek istediğinden emin misin?")) return;
    await fetch(FB_BASE + "/experience/" + id, { method:"DELETE" });
    loadExperiences();
  };

  // ─── Referans Yönetimi ────────────────────────────────────
  window.toggleRefForm = function() {
    const form = document.getElementById("ref-form");
    const btn  = document.getElementById("add-ref-btn");
    const visible = form.style.display !== "none";
    form.style.display = visible ? "none" : "block";
    btn.textContent = visible ? "+ Yeni Ekle" : "İptal";
    if (!visible) {
      ["ref-name","ref-title","ref-org","ref-relation","ref-phone","ref-email","ref-note"].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.value = "";
      });
      document.getElementById("ref-save-status").innerHTML = "";
    }
  };

  window.saveReference = async function() {
    const name  = document.getElementById("ref-name").value.trim();
    const title = document.getElementById("ref-title").value.trim();
    if (!name || !title) { alert("Ad soyad ve ünvan zorunlu!"); return; }
    const org      = document.getElementById("ref-org").value.trim();
    const relation = document.getElementById("ref-relation").value.trim();
    const phone    = document.getElementById("ref-phone").value.trim();
    const email    = document.getElementById("ref-email").value.trim();
    const note     = document.getElementById("ref-note").value.trim();
    const status   = document.getElementById("ref-save-status");
    status.innerHTML = "";
    try {
      await fetch(FB_BASE + "/references", {
        method: "POST",
        headers: {"Content-Type":"application/json"},
        body: JSON.stringify({ fields: {
          name:      { stringValue: name },
          title:     { stringValue: title },
          org:       { stringValue: org },
          relation:  { stringValue: relation },
          phone:     { stringValue: phone },
          email:     { stringValue: email },
          note:      { stringValue: note },
          createdAt: { stringValue: new Date().toISOString() },
        }})
      });
      status.innerHTML = `<p style="color:#22c55e;margin-top:8px">✅ Kaydedildi!</p>`;
      setTimeout(() => { toggleRefForm(); loadReferences(); }, 800);
    } catch(e) {
      status.innerHTML = `<p style="color:#ef4444;margin-top:8px">❌ Hata: ${e.message}</p>`;
    }
  };

  async function loadReferences() {
    const list = document.getElementById("ref-list");
    list.innerHTML = "<p class='loading-p'>Yükleniyor...</p>";
    try {
      const res = await fetch(
        "https://firestore.googleapis.com/v1/projects/hakan-efe-portfolyo/databases/(default)/documents:runQuery",
        { method:"POST", headers:{"Content-Type":"application/json"},
          body: JSON.stringify({ structuredQuery: {
            from:[{collectionId:"references"}],
            orderBy:[{field:{fieldPath:"createdAt"},direction:"DESCENDING"}], limit:20
          }})
        }
      );
      const rows = await res.json();
      const docs = rows.filter(r => r.document).map(r => r.document);
      if (!docs.length) { list.innerHTML = "<p class='loading-p'>Henüz referans eklenmedi.</p>"; return; }
      list.innerHTML = docs.map(doc => {
        const f  = doc.fields;
        const id = doc.name.split("/").pop();
        const contact = [
          f.phone?.stringValue ? `📞 ${f.phone.stringValue}` : "",
          f.email?.stringValue ? `✉️ ${f.email.stringValue}` : "",
        ].filter(Boolean).join("  |  ");
        return `<div class="ref-item">
          <div>
            <div class="ref-item-name">${f.name?.stringValue || ""}</div>
            <div class="ref-item-title">${f.title?.stringValue || ""}${f.org?.stringValue ? ` · ${f.org.stringValue}` : ""}</div>
            ${f.relation?.stringValue ? `<div class="ref-item-rel">${f.relation.stringValue}</div>` : ""}
            ${contact ? `<div class="ref-item-contact">${contact}</div>` : ""}
            ${f.note?.stringValue ? `<div class="ref-item-note">${f.note.stringValue}</div>` : ""}
          </div>
          <button class="delete-btn" onclick="deleteReference('${id}')">🗑 Sil</button>
        </div>`;
      }).join("");
    } catch(e) {
      list.innerHTML = `<p style='color:#ef4444'>Hata: ${e.message}</p>`;
    }
  }
  window.loadReferences = loadReferences;

  window.deleteReference = async function(id) {
    if (!confirm("Bu referansı silmek istediğinden emin misin?")) return;
    await fetch(FB_BASE + "/references/" + id, { method:"DELETE" });
    loadReferences();
  };
</script>
