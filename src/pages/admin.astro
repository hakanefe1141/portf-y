---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Admin Panel | Hakan Efe Blog">

<div class="admin-page">
  <!-- GİRİŞ EKRANI -->
  <div id="login-screen">
    <div class="login-box">
      <div class="login-icon">🔐</div>
      <h1>Admin Girişi</h1>
      <p>Bu sayfa sadece Hakan Efe tarafından kullanılabilir.</p>
      <input type="password" id="admin-pass" placeholder="Şifre" onkeydown="if(event.key==='Enter') checkPass()" />
      <button onclick="checkPass()">Giriş Yap</button>
      <p id="pass-error" class="error" style="display:none">Yanlış şifre!</p>
    </div>
  </div>

  <!-- ADMIN PANELİ -->
  <div id="admin-panel" style="display:none">
    <header class="admin-header">
      <div class="admin-logo">⚙️ Admin Panel</div>
      <div class="admin-actions">
        <a href="/blog" target="_blank" class="admin-btn-outline">Blogu Gör ↗</a>
        <button onclick="adminLogout()" class="admin-btn-danger">Çıkış</button>
      </div>
    </header>

    <main class="admin-main container">
      <div class="admin-layout">

        <!-- YENİ YAZI -->
        <div class="admin-card">
          <h2>✏️ Yeni Yazı</h2>
          <form id="post-form" onsubmit="publishPost(event)">
            <input type="text" id="post-title" placeholder="Başlık *" required />
            <input type="text" id="post-tag" placeholder="Etiket (örn: E-Öğrenme, LMS, ADDIE)" />
            <textarea id="post-body" rows="14" placeholder="Yazı içeriği *" required></textarea>
            <div class="form-footer">
              <span id="char-count" class="char-count">0 karakter</span>
              <button type="submit" id="publish-btn">Yayınla 🚀</button>
            </div>
            <div id="publish-success" class="success-msg" style="display:none">✅ Yazı yayınlandı!</div>
            <div id="publish-error" class="error-msg" style="display:none">❌ Hata oluştu, tekrar dene.</div>
          </form>
        </div>

        <!-- YAZI LİSTESİ -->
        <div class="admin-card">
          <div class="posts-list-header">
            <h2>📋 Yazılarım</h2>
            <button onclick="loadAdminPosts()" class="refresh-btn">↺ Yenile</button>
          </div>
          <div id="admin-posts-list">
            <p class="loading-text">Yükleniyor...</p>
          </div>
        </div>

      </div>
    </main>
  </div>
</div>

</Layout>

<style>
  .admin-page { min-height:100vh; background:var(--bg); color:var(--text); font-family:"Inter",sans-serif; }
  .container { max-width:1100px; margin:0 auto; padding:0 24px; }

  /* GİRİŞ */
  #login-screen {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .login-box {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 48px;
    width: min(400px, 90vw);
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .login-icon { font-size: 3rem; }
  .login-box h1 { font-size: 1.5rem; font-weight:700; }
  .login-box p { color: var(--text-muted); font-size:0.9rem; }

  .login-box input {
    width: 100%;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 12px 16px;
    color: var(--text);
    font-size: 1rem;
    font-family: "Inter",sans-serif;
    outline: none;
    text-align: center;
    transition: border-color 0.2s;
  }
  .login-box input:focus { border-color: var(--accent); }

  .login-box button {
    background: linear-gradient(135deg, var(--accent), #c084fc);
    color: white;
    border: none;
    border-radius: 10px;
    padding: 12px;
    font-weight: 700;
    font-size: 0.95rem;
    cursor: pointer;
    font-family: "Inter",sans-serif;
  }

  .error { color: #ef4444; font-size:0.85rem; }

  /* HEADER */
  .admin-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 32px;
    background: var(--bg-card);
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .admin-logo { font-weight:700; font-size:1.1rem; }

  .admin-actions { display:flex; gap:10px; }

  .admin-btn-outline {
    background: none;
    border: 1px solid var(--border);
    color: var(--text);
    border-radius: 8px;
    padding: 7px 16px;
    font-size:0.85rem;
    font-weight:500;
    cursor:pointer;
    text-decoration:none;
    font-family:"Inter",sans-serif;
    transition: border-color 0.2s;
  }
  .admin-btn-outline:hover { border-color: var(--accent); opacity:1; }

  .admin-btn-danger {
    background: rgba(239,68,68,0.1);
    border: 1px solid rgba(239,68,68,0.3);
    color: #ef4444;
    border-radius: 8px;
    padding: 7px 16px;
    font-size:0.85rem;
    font-weight:500;
    cursor:pointer;
    font-family:"Inter",sans-serif;
  }

  /* PANEL */
  .admin-main { padding: 32px 24px 60px; }

  .admin-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    align-items: start;
  }

  .admin-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 28px;
  }

  .admin-card h2 { font-size:1.05rem; font-weight:700; margin-bottom:20px; }

  #post-form { display:flex; flex-direction:column; gap:12px; }

  #post-form input,
  #post-form textarea {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 12px 16px;
    color: var(--text);
    font-size: 0.9rem;
    font-family: "Inter",sans-serif;
    outline: none;
    resize: vertical;
    transition: border-color 0.2s;
  }
  #post-form input:focus, #post-form textarea:focus { border-color: var(--accent); }

  .form-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .char-count { font-size:0.78rem; color:var(--text-muted); font-family:"JetBrains Mono",monospace; }

  #publish-btn {
    background: linear-gradient(135deg, var(--accent), #c084fc);
    color: white;
    border: none;
    border-radius: 8px;
    padding: 10px 24px;
    font-weight: 700;
    font-size: 0.9rem;
    cursor: pointer;
    font-family:"Inter",sans-serif;
    transition: opacity 0.2s;
  }
  #publish-btn:hover { opacity:0.88; }
  #publish-btn:disabled { opacity:0.5; cursor:not-allowed; }

  .success-msg { color: #22c55e; font-weight:600; font-size:0.9rem; }
  .error-msg { color: #ef4444; font-weight:600; font-size:0.9rem; }

  /* YAZI LİSTESİ */
  .posts-list-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:20px; }
  .refresh-btn {
    background:none; border:1px solid var(--border); color:var(--text-muted);
    border-radius:6px; padding:5px 12px; font-size:0.8rem; cursor:pointer;
    font-family:"Inter",sans-serif; transition:border-color 0.2s;
  }
  .refresh-btn:hover { border-color:var(--accent); }

  .loading-text { color:var(--text-muted); font-size:0.9rem; }

  .admin-post-item {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: 14px 0;
    border-bottom: 1px solid var(--border);
    gap: 12px;
  }
  .admin-post-item:last-child { border-bottom: none; }

  .apost-title { font-weight:600; font-size:0.9rem; margin-bottom:4px; }
  .apost-meta { font-size:0.75rem; color:var(--text-muted); font-family:"JetBrains Mono",monospace; }

  .delete-btn {
    background: rgba(239,68,68,0.08);
    border: 1px solid rgba(239,68,68,0.2);
    color: #ef4444;
    border-radius: 6px;
    padding: 5px 12px;
    font-size:0.78rem;
    cursor:pointer;
    white-space:nowrap;
    font-family:"Inter",sans-serif;
    flex-shrink:0;
  }
  .delete-btn:hover { background: rgba(239,68,68,0.15); }

  @media (max-width:768px) {
    .admin-layout { grid-template-columns:1fr; }
    .admin-header { padding:12px 16px; }
  }
</style>

<script>
  const ADMIN_PASS = "hakanefe2026";
  const FB_BASE = "https://firestore.googleapis.com/v1/projects/hakan-efe-portfolyo/databases/(default)/documents/blog";

  // Şifre kontrolü
  function checkPass() {
    const pass = (document.getElementById("admin-pass") as HTMLInputElement).value;
    if (pass === ADMIN_PASS) {
      localStorage.setItem("admin_auth", "1");
      showPanel();
    } else {
      document.getElementById("pass-error").style.display = "block";
    }
  }
  window.checkPass = checkPass;

  function showPanel() {
    document.getElementById("login-screen").style.display = "none";
    document.getElementById("admin-panel").style.display = "block";
    loadAdminPosts();
  }

  // Sayfa açılışında oturum kontrolü
  if (localStorage.getItem("admin_auth") === "1") showPanel();

  window.adminLogout = function() {
    localStorage.removeItem("admin_auth");
    location.reload();
  };

  // Karakter sayacı
  document.getElementById("post-body")?.addEventListener("input", function() {
    document.getElementById("char-count").textContent = this.value.length + " karakter";
  });

  // Yazı yayınla
  window.publishPost = async function(e) {
    e.preventDefault();
    const btn = document.getElementById("publish-btn") as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = "Yayınlanıyor...";
    document.getElementById("publish-success").style.display = "none";
    document.getElementById("publish-error").style.display = "none";

    const body = {
      fields: {
        title:  { stringValue: (document.getElementById("post-title") as HTMLInputElement).value },
        tag:    { stringValue: (document.getElementById("post-tag") as HTMLInputElement).value || "Genel" },
        body:   { stringValue: (document.getElementById("post-body") as HTMLTextAreaElement).value },
        author: { stringValue: "Hakan Efe" },
        date:   { stringValue: new Date().toISOString() },
      }
    };

    try {
      await fetch(FB_BASE, { method:"POST", headers:{"Content-Type":"application/json"}, body: JSON.stringify(body) });
      document.getElementById("publish-success").style.display = "block";
      (document.getElementById("post-form") as HTMLFormElement).reset();
      document.getElementById("char-count").textContent = "0 karakter";
      loadAdminPosts();
    } catch {
      document.getElementById("publish-error").style.display = "block";
    } finally {
      btn.disabled = false;
      btn.textContent = "Yayınla 🚀";
    }
  };

  // Yazıları listele
  async function loadAdminPosts() {
    const list = document.getElementById("admin-posts-list");
    list.innerHTML = "<p class='loading-text'>Yükleniyor...</p>";
    try {
      const res = await fetch(FB_BASE + "?orderBy=date%20desc&pageSize=20");
      const data = await res.json();
      const docs = data.documents || [];

      if (!docs.length) { list.innerHTML = "<p class='loading-text'>Henüz yazı yok.</p>"; return; }

      list.innerHTML = docs.map(doc => {
        const f = doc.fields;
        const id = doc.name.split("/").pop();
        const date = new Date(f.date?.stringValue || "").toLocaleDateString("tr-TR");
        return `<div class="admin-post-item">
          <div>
            <div class="apost-title">${f.title?.stringValue || ""}</div>
            <div class="apost-meta">${f.tag?.stringValue || "Genel"} · ${date}</div>
          </div>
          <button class="delete-btn" onclick="deletePost('${id}')">🗑 Sil</button>
        </div>`;
      }).join("");
    } catch {
      list.innerHTML = "<p style='color:#ef4444'>Yüklenemedi.</p>";
    }
  }
  window.loadAdminPosts = loadAdminPosts;

  // Yazı sil
  window.deletePost = async function(id) {
    if (!confirm("Bu yazıyı silmek istediğinden emin misin?")) return;
    try {
      await fetch(FB_BASE + "/" + id, { method:"DELETE" });
      loadAdminPosts();
    } catch { alert("Silinemedi."); }
  };
</script>
