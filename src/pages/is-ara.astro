---
import Layout from "../layouts/Layout.astro";
---

<Layout title="İş İlanı Ara | Hakan Efe" description="Eğitim Teknoloğu iş ilanlarını tek ekranda ara">

<div class="job-page">

  <header class="job-header">
    <a href="/" class="back-link">← Portföye Dön</a>
    <div class="header-content">
      <span class="job-badge">💼 İş Arama Aracı</span>
      <h1>İş İlanı Ara</h1>
      <p>Anahtar kelimeyi gir — ilanlar buraya gelsin. Remote & uluslararası pozisyonlar için İngilizce ara.</p>
    </div>
  </header>

  <main class="job-main">

    <!-- ARAMA FORMU -->
    <div class="search-card">
      <div class="search-row">
        <div class="search-input-wrap">
          <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <input type="text" id="keyword" placeholder="örn: Eğitim Teknoloğu, Instructional Designer..." />
        </div>
        <div class="search-input-wrap loc-wrap">
          <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <input type="text" id="location" placeholder="Şehir (İstanbul, Ankara...)" />
        </div>
        <button class="search-btn" onclick="searchJobs(1)">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          Ara
        </button>
      </div>

      <div class="quick-tags">
        <span class="qtag-label">Hızlı:</span>
        <button onclick="setAndSearch('Instructional Designer')">Instructional Designer</button>
        <button onclick="setAndSearch('E-Learning Developer')">E-Learning Developer</button>
        <button onclick="setAndSearch('Learning Designer')">Learning Designer</button>
        <button onclick="setAndSearch('LMS Administrator')">LMS Administrator</button>
        <button onclick="setAndSearch('Education Technology')">Education Technology</button>
        <button onclick="setAndSearch('Training Specialist')">Training Specialist</button>
        <button onclick="setAndSearch('Content Designer')">Content Designer</button>
      </div>
    </div>

    <!-- TÜRKİYE PLATFORMLARI -->
    <div class="tr-section">
      <div class="tr-label">🇹🇷 Türkiye'de Ara</div>
      <div class="tr-platforms" id="tr-platforms">
        <button onclick="openTR('kariyer')" class="tr-btn kariyer-btn">Kariyer.net</button>
        <button onclick="openTR('linkedin')" class="tr-btn linkedin-btn">LinkedIn</button>
        <button onclick="openTR('yenibiris')" class="tr-btn yenibiris-btn">Yeni Bir İş</button>
        <button onclick="openTR('indeed')" class="tr-btn indeed-btn">Indeed TR</button>
      </div>
    </div>

    <!-- SONUÇLAR -->
    <div id="results-section">
      <!-- JS ile doldurulacak -->
      <div class="empty-state">
        <div class="empty-icon">🔍</div>
        <p>Arama yapmak için yukarıya bir kelime gir.</p>
      </div>
    </div>

  </main>

  <footer class="job-footer">
    <p>Hakan Efe · <a href="mailto:hakanefe1141@gmail.com">hakanefe1141@gmail.com</a> · <a href="/">hakanefe.com</a></p>
  </footer>

</div>
</Layout>

<style is:global>
  .job-page { min-height:100vh; background:var(--bg); color:var(--text); font-family:"Inter",sans-serif; }

  .job-header {
    background: linear-gradient(135deg, #0f0f1a, #0a1628);
    border-bottom: 1px solid #2a2a3e;
    padding: 28px 40px 36px;
  }
  .back-link {
    display: inline-flex; align-items: center;
    color: #a78bfa; font-size: 0.875rem; font-weight: 500;
    padding: 7px 14px; border: 1px solid #2a2a3e; border-radius: 8px;
    text-decoration: none; margin-bottom: 20px; transition: border-color 0.2s;
  }
  .back-link:hover { border-color: #7c3aed; opacity:1; }
  .job-badge {
    display: inline-block;
    background: rgba(34,197,94,0.15); border: 1px solid rgba(34,197,94,0.3);
    color: #86efac; border-radius: 100px;
    padding: 4px 14px; font-size: 0.75rem; font-weight: 600; margin-bottom: 14px;
  }
  .header-content h1 { font-size: clamp(1.5rem,4vw,2rem); font-weight: 700; color: white; margin-bottom: 8px; }
  .header-content p { color: #94a3b8; font-size: 0.9rem; }

  .job-main { max-width: 860px; margin: 0 auto; padding: 32px 24px 60px; display: flex; flex-direction: column; gap: 24px; }

  /* SEARCH */
  .search-card {
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: 16px; padding: 22px;
  }
  .search-row { display: flex; gap: 10px; margin-bottom: 14px; flex-wrap: wrap; }
  .search-input-wrap {
    flex: 1; min-width: 180px;
    position: relative; display: flex; align-items: center;
  }
  .search-icon { position: absolute; left: 13px; color: var(--text-muted); pointer-events: none; }
  .search-input-wrap input {
    width: 100%;
    background: var(--bg); border: 1px solid var(--border);
    border-radius: 10px; padding: 11px 14px 11px 40px;
    color: var(--text); font-size: 0.92rem; font-family: "Inter",sans-serif;
    outline: none; transition: border-color 0.2s;
  }
  .search-input-wrap input:focus { border-color: #22c55e; }
  .loc-wrap { max-width: 200px; }
  .search-btn {
    background: linear-gradient(135deg, #22c55e, #16a34a);
    color: white; border: none; border-radius: 10px;
    padding: 11px 22px; font-size: 0.9rem; font-weight: 700;
    cursor: pointer; font-family: "Inter",sans-serif;
    display: flex; align-items: center; gap: 7px; white-space: nowrap;
    transition: opacity 0.2s, transform 0.2s;
  }
  .search-btn:hover { opacity: 0.9; transform: translateY(-1px); }
  .search-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

  .quick-tags { display: flex; align-items: center; gap: 7px; flex-wrap: wrap; }
  .qtag-label { font-size: 0.72rem; color: var(--text-muted); }
  .quick-tags button {
    background: var(--tag-bg); color: var(--tag-text);
    border: 1px solid var(--border); border-radius: 100px;
    padding: 3px 11px; font-size: 0.73rem; font-weight: 500;
    cursor: pointer; font-family: "Inter",sans-serif;
    transition: border-color 0.15s, background 0.15s;
  }
  .quick-tags button:hover { border-color: #22c55e; background: rgba(34,197,94,0.08); color: #22c55e; }

  /* TÜRKİYE PLATFORMLARI */
  .tr-section {
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: 14px; padding: 16px 20px;
    display: flex; align-items: center; gap: 14px; flex-wrap: wrap;
  }
  .tr-label { font-size: 0.82rem; font-weight: 700; color: var(--text-muted); white-space: nowrap; }
  .tr-platforms { display: flex; gap: 8px; flex-wrap: wrap; }
  .tr-btn {
    border: none; border-radius: 8px; padding: 7px 16px;
    font-size: 0.8rem; font-weight: 700; cursor: pointer;
    font-family: "Inter",sans-serif; color: white;
    transition: opacity 0.2s, transform 0.2s;
  }
  .tr-btn:hover { opacity: 0.85; transform: translateY(-1px); }
  .kariyer-btn  { background: #e53935; }
  .linkedin-btn { background: #0077b5; }
  .yenibiris-btn{ background: #f59e0b; }
  .indeed-btn   { background: #003a9b; }

  /* LOADING */
  .loading-state {
    display: flex; align-items: center; gap: 14px;
    padding: 48px 24px;
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: 16px; color: var(--text-muted); font-size: 0.9rem;
  }
  .job-spinner {
    width: 22px; height: 22px;
    border: 2.5px solid var(--border);
    border-top-color: #22c55e;
    border-radius: 50%;
    animation: spin 0.7s linear infinite; flex-shrink: 0;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* RESULTS HEADER */
  .results-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 14px; flex-wrap: wrap; gap: 8px;
  }
  .results-count { font-size: 0.82rem; color: var(--text-muted); font-family: "JetBrains Mono",monospace; }
  .results-title { font-size: 1rem; font-weight: 700; }

  /* JOB CARD */
  .jobs-list { display: flex; flex-direction: column; gap: 10px; }

  .job-card {
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: 14px; padding: 20px 22px;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
    animation: fadeUp 0.3s ease backwards;
  }
  @keyframes fadeUp { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }
  .job-card:hover {
    border-color: #22c55e;
    box-shadow: 0 4px 20px rgba(34,197,94,0.1);
    transform: translateY(-1px);
  }

  .job-card-top {
    display: flex; align-items: flex-start;
    justify-content: space-between; gap: 12px; margin-bottom: 10px;
  }
  .job-title {
    font-size: 0.97rem; font-weight: 700; color: var(--text);
    line-height: 1.35; flex: 1;
  }
  .job-date {
    font-size: 0.68rem; color: var(--text-muted);
    font-family: "JetBrains Mono",monospace; white-space: nowrap; flex-shrink: 0;
    margin-top: 2px;
  }

  .job-meta {
    display: flex; align-items: center; gap: 12px;
    margin-bottom: 10px; flex-wrap: wrap;
  }
  .job-company {
    font-size: 0.82rem; font-weight: 600;
    color: #22c55e;
  }
  .job-location {
    display: flex; align-items: center; gap: 4px;
    font-size: 0.78rem; color: var(--text-muted);
  }
  .job-salary {
    font-size: 0.75rem; font-weight: 600;
    background: rgba(34,197,94,0.1); color: #22c55e;
    border-radius: 100px; padding: 2px 10px;
  }

  .job-desc {
    font-size: 0.83rem; color: var(--text-muted);
    line-height: 1.7;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 14px;
  }

  .job-footer-row {
    display: flex; align-items: center;
    justify-content: space-between; gap: 12px;
    padding-top: 12px; border-top: 1px solid var(--border);
  }
  .job-source {
    font-size: 0.7rem; color: var(--text-muted);
    font-family: "JetBrains Mono",monospace;
  }
  .apply-btn {
    background: #22c55e; color: white;
    border: none; border-radius: 8px;
    padding: 7px 18px; font-size: 0.8rem; font-weight: 700;
    cursor: pointer; font-family: "Inter",sans-serif;
    text-decoration: none; display: inline-flex; align-items: center; gap: 5px;
    transition: opacity 0.2s;
  }
  .apply-btn:hover { opacity: 0.88; }

  /* PAGINATION */
  .pagination {
    display: flex; align-items: center; justify-content: center;
    gap: 8px; padding-top: 8px;
  }
  .page-btn {
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: 8px; padding: 7px 14px;
    font-size: 0.82rem; font-weight: 600;
    cursor: pointer; color: var(--text); font-family: "Inter",sans-serif;
    transition: border-color 0.15s, background 0.15s;
  }
  .page-btn:hover:not(:disabled) { border-color: #22c55e; background: rgba(34,197,94,0.08); color: #22c55e; }
  .page-btn:disabled { opacity: 0.3; cursor: not-allowed; }
  .page-btn.active { background: #22c55e; color: white; border-color: #22c55e; }
  .page-info { font-size: 0.78rem; color: var(--text-muted); font-family: "JetBrains Mono",monospace; }

  /* ERROR / EMPTY */
  .empty-state {
    text-align: center; padding: 56px 24px;
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: 16px;
  }
  .empty-icon { font-size: 2.8rem; margin-bottom: 12px; opacity: 0.5; }
  .empty-state p { color: var(--text-muted); font-size: 0.9rem; }

  .error-state {
    text-align: center; padding: 40px 24px;
    background: rgba(239,68,68,0.05); border: 1px solid rgba(239,68,68,0.2);
    border-radius: 16px; color: #ef4444; font-size: 0.88rem;
  }

  /* FOOTER */
  .job-footer { text-align: center; padding: 28px; border-top: 1px solid var(--border); color: var(--text-muted); font-size: 0.82rem; }

  @media (max-width: 640px) {
    .job-header { padding: 20px 20px 28px; }
    .loc-wrap { max-width: 100%; }
    .search-btn { width: 100%; justify-content: center; }
    .job-card-top { flex-direction: column; gap: 4px; }
  }
</style>

<script is:inline>
  const ADZUNA_ID  = "d9dfe595";
  const ADZUNA_KEY = "1c99a0e4e49e3a70631b4a75eb0f422a";

  let currentPage = 1;
  let lastKeyword = "";
  let lastLocation = "";
  let totalCount = 0;
  const PAGE_SIZE = 10;

  const TR_URLS = {
    kariyer:  kw => `https://www.kariyer.net/is-ilanlari?q=${encodeURIComponent(kw)}`,
    linkedin: kw => `https://www.linkedin.com/jobs/search/?keywords=${encodeURIComponent(kw)}&location=T%C3%BCrkiye`,
    yenibiris:kw => `https://www.yenibiris.com/is-ilanlari?Keywords=${encodeURIComponent(kw)}`,
    indeed:   kw => `https://tr.indeed.com/jobs?q=${encodeURIComponent(kw)}`,
  };

  window.openTR = function(platform) {
    const kw = document.getElementById("keyword").value.trim() || "Eğitim Teknoloğu";
    window.open(TR_URLS[platform]?.(kw), "_blank", "noopener");
  };

  window.setAndSearch = function(val) {
    document.getElementById("keyword").value = val;
    searchJobs(1);
  };

  function fetchWithTimeout(url, options, ms) {
    const controller = new AbortController();
    const timer = setTimeout(() => controller.abort(), ms);
    return fetch(url, { ...options, signal: controller.signal })
      .finally(() => clearTimeout(timer));
  }

  window.searchJobs = async function(page) {
    const kw  = document.getElementById("keyword").value.trim();
    const loc = document.getElementById("location").value.trim();
    if (!kw) { document.getElementById("keyword").focus(); return; }

    currentPage = page;
    lastKeyword = kw;
    lastLocation = loc;

    const section = document.getElementById("results-section");
    section.innerHTML = `<div class="loading-state"><div class="job-spinner"></div><span>"${kw}" için ilanlar aranıyor...</span></div>`;

    const btn = document.querySelector(".search-btn");
    if (btn) btn.disabled = true;

    const params = new URLSearchParams({
      app_id: ADZUNA_ID,
      app_key: ADZUNA_KEY,
      what: kw,
      where: loc || "",
      results_per_page: PAGE_SIZE,
      "content-type": "application/json",
    });

    const url = `https://api.adzuna.com/v1/api/jobs/gb/search/${page}?${params}`;

    try {
      const res  = await fetchWithTimeout(url, {}, 12000);
      const data = await res.json();
      if (!data || !data.results) throw new Error("Sonuç bulunamadı.");
      totalCount = data.count || 0;
      renderResults(data.results, kw, page);
    } catch(e) {
      section.innerHTML = `<div class="error-state">⚠️ İlanlar yüklenemedi.<br/><small>${e.message}</small></div>`;
    } finally {
      if (btn) btn.disabled = false;
    }

  };

  function renderResults(jobs, kw, page) {
    const section = document.getElementById("results-section");
    if (!jobs || !jobs.length) {
      section.innerHTML = `<div class="empty-state"><div class="empty-icon">😔</div><p>"${kw}" için ilan bulunamadı. Farklı bir anahtar kelime dene.</p></div>`;
      return;
    }

    const totalPages = Math.ceil(totalCount / PAGE_SIZE) || 1;

    const cardsHtml = jobs.map((job, i) => {
      const title   = cleanHtml(job.title || "İlan");
      const company = cleanHtml(job.company?.display_name || "");
      const loc     = cleanHtml(job.location?.display_name || "");
      const desc    = cleanHtml(job.description || "");
      const salMin  = job.salary_min ? Math.round(job.salary_min).toLocaleString("tr-TR") : null;
      const salMax  = job.salary_max ? Math.round(job.salary_max).toLocaleString("tr-TR") : null;
      const salary  = salMin ? `<span class="job-salary">💰 ${salMin}${salMax ? " – " + salMax : ""} ₺</span>` : "";
      const date    = job.created ? formatDate(job.created) : "";
      const link    = job.redirect_url || "#";
      const source  = "Adzuna";

      return `<div class="job-card" style="animation-delay:${i*0.05}s">
        <div class="job-card-top">
          <div class="job-title">${title}</div>
          ${date ? `<div class="job-date">${date}</div>` : ""}
        </div>
        <div class="job-meta">
          ${company ? `<span class="job-company">🏢 ${company}</span>` : ""}
          ${loc     ? `<span class="job-location">📍 ${loc}</span>` : ""}
          ${salary}
        </div>
        ${desc ? `<div class="job-desc">${desc}</div>` : ""}
        <div class="job-footer-row">
          <span class="job-source">via ${source}</span>
          <a href="${link}" target="_blank" rel="noopener" class="apply-btn">Başvur →</a>
        </div>
      </div>`;
    }).join("");

    // Sayfalama
    const prevDisabled = page <= 1 ? "disabled" : "";
    const nextDisabled = page >= totalPages ? "disabled" : "";
    const paginationHtml = totalPages > 1 ? `
      <div class="pagination">
        <button class="page-btn" onclick="searchJobs(${page-1})" ${prevDisabled}>← Önceki</button>
        <span class="page-info">${page} / ${totalPages}</span>
        <button class="page-btn" onclick="searchJobs(${page+1})" ${nextDisabled}>Sonraki →</button>
      </div>` : "";

    section.innerHTML = `
      <div class="results-header">
        <div>
          <div class="results-title">"${kw}" ilanları</div>
          <div class="results-count">${totalCount > 0 ? totalCount.toLocaleString("tr-TR") + " ilan bulundu" : jobs.length + " ilan"}</div>
        </div>
      </div>
      <div class="jobs-list">${cardsHtml}</div>
      ${paginationHtml}`;
  }

  function cleanHtml(str) {
    return str.replace(/<[^>]*>/g, "").replace(/&amp;/g,"&").replace(/&lt;/g,"<").replace(/&gt;/g,">").replace(/&nbsp;/g," ").trim();
  }

  function formatDate(str) {
    try {
      return new Date(str).toLocaleDateString("tr-TR", { day:"numeric", month:"short", year:"numeric" });
    } catch { return ""; }
  }

  // Enter ile ara
  document.getElementById("keyword").addEventListener("keydown", e => { if(e.key==="Enter") searchJobs(1); });
  document.getElementById("location").addEventListener("keydown", e => { if(e.key==="Enter") searchJobs(1); });

  // Boş açılır, kullanıcı yazar
</script>
