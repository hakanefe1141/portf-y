---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404 – Sayfa Bulunamadı | Hakan Efe" description="Aradığınız sayfa bulunamadı.">
  <div class="not-found">
    <div class="nf-inner">
      <div class="nf-code">404</div>
      <h1>Sayfa Bulunamadı</h1>
      <p>Aradığın sayfa taşınmış, silinmiş ya da hiç var olmamış olabilir.</p>
      <div class="nf-actions">
        <a href="/" class="btn-primary">← Ana Sayfaya Dön</a>
        <a href="/#blog" class="btn-secondary">Blog'a Git</a>
      </div>
    </div>
  </div>
</Layout>

<style>
  .not-found {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 40px 24px;
    background: var(--bg);
  }

  .nf-inner {
    max-width: 480px;
  }

  .nf-code {
    font-size: clamp(6rem, 20vw, 10rem);
    font-weight: 800;
    font-family: "JetBrains Mono", monospace;
    background: linear-gradient(135deg, #7c3aed, #c084fc);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
    margin-bottom: 16px;
  }

  h1 {
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 12px;
  }

  p {
    color: var(--text-muted);
    font-size: 1rem;
    line-height: 1.7;
    margin-bottom: 36px;
  }

  .nf-actions {
    display: flex;
    gap: 14px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-primary {
    background: var(--accent);
    color: white !important;
    padding: 12px 28px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.92rem;
    transition: opacity 0.2s, transform 0.2s;
  }
  .btn-primary:hover { opacity: 0.88 !important; transform: translateY(-2px); }

  .btn-secondary {
    background: transparent;
    color: var(--text) !important;
    padding: 12px 28px;
    border-radius: 8px;
    border: 1px solid var(--border);
    font-weight: 600;
    font-size: 0.92rem;
    transition: border-color 0.2s, transform 0.2s;
  }
  .btn-secondary:hover { border-color: var(--accent); opacity: 1 !important; transform: translateY(-2px); }
</style>
