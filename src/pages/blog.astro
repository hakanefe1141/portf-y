---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Blog | Hakan Efe – Eğitim Teknoloğu" description="Hakan Efe'nin eğitim teknolojisi, e-öğrenme, LMS, ADDIE modeli ve instructional design üzerine yazıları.">

<div class="blog-page">
  <header class="blog-header">
    <a href="/" class="back-link">← Portföye Dön</a>
    <div>
      <span class="blog-badge">Eğitim Teknolojisi</span>
      <h1>Blog</h1>
      <p>Eğitim teknolojisi, e-öğrenme ve dijital pedagoji üzerine yazılar.</p>
    </div>
  </header>

  <main class="blog-main container">
    <div id="posts-loading" class="loading-state">
      <div class="loading-spinner"></div>
      <p>Yazılar yükleniyor...</p>
    </div>
    <div id="posts-empty" class="empty-state" style="display:none">
      <span>📝</span>
      <p>Henüz yazı yok. Yakında yeni içerikler gelecek!</p>
    </div>
    <div id="posts-grid" class="posts-grid"></div>
  </main>

  <footer class="blog-footer">
    <p>Hakan Efe · <a href="mailto:hakanefe1141@gmail.com">hakanefe1141@gmail.com</a></p>
  </footer>
</div>

</Layout>

<style>
  .blog-page { min-height:100vh; background:var(--bg); color:var(--text); font-family:"Inter",sans-serif; }
  .container { max-width:900px; margin:0 auto; padding:0 24px; }

  .blog-header {
    background: linear-gradient(135deg,#0f0f1a,#1a0a2e);
    border-bottom: 1px solid #2a2a3e;
    padding: 28px 40px;
    display: flex;
    align-items: center;
    gap: 28px;
    flex-wrap: wrap;
  }

  .back-link {
    color: var(--accent-light);
    font-size: 0.875rem;
    font-weight: 500;
    padding: 8px 16px;
    border: 1px solid #2a2a3e;
    border-radius: 8px;
    text-decoration: none;
    white-space: nowrap;
    transition: border-color 0.2s;
    flex-shrink: 0;
  }
  .back-link:hover { border-color: var(--accent); opacity:1; }

  .blog-badge {
    display: inline-block;
    background: rgba(124,58,237,0.15);
    border: 1px solid var(--accent);
    color: var(--accent-light);
    border-radius: 100px;
    padding: 3px 14px;
    font-size: 0.75rem;
    margin-bottom: 8px;
  }

  .blog-header h1 { font-size:1.8rem; font-weight:700; color:#e2e8f0; margin-bottom:6px; }
  .blog-header p { color:#64748b; font-size:0.9rem; }

  .blog-main { padding: 40px 24px 60px; }

  .loading-state, .empty-state {
    text-align: center;
    padding: 80px 20px;
    color: var(--text-muted);
  }

  .loading-spinner {
    width: 36px; height: 36px;
    border: 3px solid var(--border);
    border-top-color: var(--accent);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
    margin: 0 auto 16px;
  }

  @keyframes spin { to { transform: rotate(360deg); } }

  .empty-state span { font-size: 3rem; display:block; margin-bottom:12px; }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px;
  }

  .post-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 28px;
    cursor: pointer;
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .post-card:hover {
    border-color: var(--accent);
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(124,58,237,0.12);
    opacity: 1;
  }

  .post-tag {
    display: inline-block;
    background: var(--tag-bg);
    color: var(--tag-text);
    border-radius: 6px;
    padding: 3px 10px;
    font-size: 0.75rem;
    font-weight: 500;
    font-family: "JetBrains Mono", monospace;
    align-self: flex-start;
  }

  .post-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.4;
  }

  .post-excerpt {
    color: var(--text-muted);
    font-size: 0.875rem;
    line-height: 1.7;
    flex: 1;
  }

  .post-meta {
    display: flex;
    justify-content: space-between;
    font-size: 0.75rem;
    color: var(--text-muted);
    font-family: "JetBrains Mono", monospace;
    border-top: 1px solid var(--border);
    padding-top: 12px;
  }

  /* POST MODAL */
  #post-modal {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.8);
    z-index: 9000;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(6px);
    padding: 24px;
  }
  #post-modal.open { display: flex; }

  #post-box {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 40px;
    width: min(720px, 100%);
    max-height: 85vh;
    overflow-y: auto;
    position: relative;
    animation: quiz-in 0.3s ease;
  }

  .post-close {
    position: absolute;
    top: 16px; right: 16px;
    background: none; border: none;
    color: var(--text-muted); font-size: 1.2rem;
    cursor: pointer;
  }

  #post-full-tag { margin-bottom:16px; }
  #post-full-title { font-size:1.6rem; font-weight:700; margin-bottom:8px; line-height:1.3; }
  #post-full-meta { color:var(--text-muted); font-size:0.8rem; margin-bottom:24px; font-family:"JetBrains Mono",monospace; }
  #post-full-body {
    color: var(--text-dim);
    line-height: 1.85;
    font-size: 0.95rem;
    white-space: pre-wrap;
  }

  .blog-footer {
    text-align: center;
    padding: 24px;
    border-top: 1px solid var(--border);
    color: var(--text-muted);
    font-size: 0.82rem;
  }

  @media (max-width: 600px) {
    .blog-header { flex-direction: column; align-items: flex-start; padding: 20px; }
    .posts-grid { grid-template-columns: 1fr; }
    #post-box { padding: 24px; }
  }
</style>

<!-- POST MODAL -->
<div id="post-modal" onclick="closePost(event)">
  <div id="post-box">
    <button class="post-close" onclick="closePost()">✕</button>
    <span class="post-tag" id="post-full-tag"></span>
    <h2 id="post-full-title"></h2>
    <p id="post-full-meta"></p>
    <div id="post-full-body"></div>
  </div>
</div>

<script>
  const FB_URL = "https://firestore.googleapis.com/v1/projects/hakan-efe-portfolyo/databases/(default)/documents/blog?orderBy=date%20desc&pageSize=20";

  async function loadPosts() {
    try {
      const res = await fetch(FB_URL);
      const data = await res.json();
      const docs = data.documents || [];

      document.getElementById("posts-loading").style.display = "none";

      if (!docs.length) {
        document.getElementById("posts-empty").style.display = "block";
        return;
      }

      const grid = document.getElementById("posts-grid");
      grid.innerHTML = docs.map(doc => {
        const f = doc.fields;
        const id = doc.name.split("/").pop();
        const date = new Date(f.date?.stringValue || "").toLocaleDateString("tr-TR", { day:"numeric", month:"long", year:"numeric" });
        const excerpt = (f.body?.stringValue || "").slice(0, 140) + "...";
        return `<div class="post-card" onclick="openPost('${id}')">
          <span class="post-tag">${f.tag?.stringValue || "Genel"}</span>
          <div class="post-title">${f.title?.stringValue || ""}</div>
          <div class="post-excerpt">${excerpt}</div>
          <div class="post-meta">
            <span>${f.author?.stringValue || "Hakan Efe"}</span>
            <span>${date}</span>
          </div>
        </div>`;
      }).join("");

      // posts verilerini sakla
      window._posts = {};
      docs.forEach(doc => {
        const id = doc.name.split("/").pop();
        window._posts[id] = doc.fields;
      });

    } catch {
      document.getElementById("posts-loading").innerHTML = "<p style='color:#ef4444'>Yazılar yüklenemedi.</p>";
    }
  }

  window.openPost = function(id) {
    const f = window._posts?.[id];
    if (!f) return;
    const date = new Date(f.date?.stringValue || "").toLocaleDateString("tr-TR", { day:"numeric", month:"long", year:"numeric" });
    document.getElementById("post-full-tag").textContent = f.tag?.stringValue || "Genel";
    document.getElementById("post-full-title").textContent = f.title?.stringValue || "";
    document.getElementById("post-full-meta").textContent = `${f.author?.stringValue || "Hakan Efe"} · ${date}`;
    document.getElementById("post-full-body").textContent = f.body?.stringValue || "";
    document.getElementById("post-modal").classList.add("open");
  };

  window.closePost = function(e?: any) {
    if (!e || e.target === document.getElementById("post-modal"))
      document.getElementById("post-modal").classList.remove("open");
  };

  loadPosts();
</script>
