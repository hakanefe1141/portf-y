    document.getElementById("doc-body").innerHTML = html;
    const sec = document.getElementById("doc-section");
    sec.style.display = "block";
    sec.scrollIntoView({ behavior: "smooth", block: "start" });
  }

  function printDoc() { window.print(); }

  function copyDoc() {
    const blocks = document.querySelectorAll(".content-block");
    let text = document.getElementById("doc-title").textContent + "\n\n";
    blocks.forEach(b => {
      const label = b.querySelector(".content-label")?.textContent || "";
      const items = [...b.querySelectorAll(".content-list li")].map(li => "  • " + li.textContent).join("\n");
      const para  = b.querySelector(".content-text")?.textContent || "";
      text += `${label}\n${items || para}\n\n`;
    });
    navigator.clipboard.writeText(text).then(() => {
      const btn = document.getElementById("copy-btn");
      btn.textContent = "✅ Kopyalandı!";
      setTimeout(() => btn.textContent = "📋 Kopyala", 2000);
    });
  }
</script>
